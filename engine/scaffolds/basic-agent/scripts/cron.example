# basic-agent cron example (Linux default scheduler path).
# Copy into your crontab (crontab -e) and edit the absolute paths for your host.
# Runs every 15 minutes. Logs go into trajectories/cron.log; per-run trajectories
# are still written by the runtime into trajectories/<run-id>.jsonl.
*/15 * * * * cd /home/ubuntu/agents/builders/basic-agent-builder/basic-agent && /usr/bin/env node ./dist/entry/scheduled.js "scheduled heartbeat" >> ./trajectories/cron.log 2>&1
