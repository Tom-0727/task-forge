#!/usr/bin/env bash
# update-runtime — Update platform infrastructure files and managed rules files
# without touching agent-authored notes or mailbox history
#
# Usage:
#   ./update-runtime --workdir /abs/path/to/agent
#   ./update-runtime --all                        # update all registered agents
#   ./update-runtime --workdir /path --dry-run     # preview changes without writing

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SHARED_TEMPLATE_DIR="${SCRIPT_DIR}/shared"
PROVIDER_TEMPLATE_ROOT="${SCRIPT_DIR}/providers"

DRY_RUN=0
UPDATE_ALL=0
WORKDIR=""
RESTART=0

usage() {
  cat <<'USAGE'
Usage:
  ./update-runtime --workdir /abs/path/to/agent [--dry-run] [--restart]
  ./update-runtime --all [--dry-run] [--restart]

Options:
  --workdir PATH   Path to a single agent workspace to update
  --all            Update all agents registered in the platform registry
  --dry-run        Show what would be updated without making changes
  --restart        Restart the agent after updating (stop -> update -> start)
  --help           Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --workdir)   WORKDIR="$2"; shift 2 ;;
    --all)       UPDATE_ALL=1; shift ;;
    --dry-run)   DRY_RUN=1; shift ;;
    --restart)   RESTART=1; shift ;;
    --help|-h)   usage; exit 0 ;;
    *)           echo "Unknown argument: $1"; usage; exit 1 ;;
  esac
done

# ── Helpers ──────────────────────────────────────────────────────────

resolve_path() {
  python3 - "$1" <<'PY'
from pathlib import Path
import sys
print(Path(sys.argv[1]).expanduser().resolve())
PY
}

detect_provider() {
  local dir="$1"
  if [[ -f "${dir}/run_claude.py" ]]; then
    echo "claude"
  elif [[ -f "${dir}/run_codex.mjs" ]]; then
    echo "codex"
  else
    # fallback: check Runtime
    local prov_file="${dir}/Runtime/runtime_provider"
    if [[ -f "${prov_file}" ]]; then
      cat "${prov_file}"
    else
      echo ""
    fi
  fi
}

provider_skill_root() {
  case "$1" in
    codex) echo ".agents" ;;
    claude) echo ".claude" ;;
  esac
}

provider_rules_filename() {
  case "$1" in
    codex) echo "AGENTS.md" ;;
    claude) echo "CLAUDE.md" ;;
  esac
}

provider_agent_root() {
  case "$1" in
    codex) echo ".codex" ;;
    claude) echo ".claude" ;;
  esac
}

provider_episode_planner_name() {
  case "$1" in
    codex) echo "episode_planner" ;;
    claude) echo "episode-planner" ;;
  esac
}

provider_episode_evaluator_name() {
  case "$1" in
    codex) echo "episode_evaluator" ;;
    claude) echo "episode-evaluator" ;;
  esac
}

provider_mailbox_read_summary_cmd() {
  case "$1" in
    codex) echo "mailbox-read --summary" ;;
    claude) echo "uv run python .claude/skills/mailbox-operate/scripts/read_mailbox.py --summary" ;;
  esac
}

provider_mailbox_read_contact_cmd() {
  case "$1" in
    codex) echo "mailbox-read --from <contact>" ;;
    claude) echo "uv run python .claude/skills/mailbox-operate/scripts/read_mailbox.py --from <contact>" ;;
  esac
}

read_agent_name() {
  local dir="$1"
  local name_file="${dir}/Runtime/agent_name"
  if [[ -f "${name_file}" ]]; then
    tr -d '\r' < "${name_file}"
  else
    basename "${dir}"
  fi
}

# Re-render a template to a destination, preserving the agent's own variables
render_template() {
  local src="$1"
  local dst="$2"
  local agent_name="$3"
  local rules_filename="$4"
  local provider="$5"

  SRC="$src" \
  DST="$dst" \
  AGENT_NAME="$agent_name" \
  GOAL="" \
  CREATED_AT="" \
  CREATED_DATE="" \
  RULES_FILENAME="$rules_filename" \
  PROVIDER_SKILL_ROOT="$(provider_skill_root "${provider}")" \
  PROVIDER_SKILLS_DIR="$(provider_skill_root "${provider}")/skills" \
  PROVIDER_AGENTS_DIR="$(provider_agent_root "${provider}")/agents" \
  EPISODE_PLANNER_NAME="$(provider_episode_planner_name "${provider}")" \
  EPISODE_EVALUATOR_NAME="$(provider_episode_evaluator_name "${provider}")" \
  MAILBOX_READ_SUMMARY_CMD="$(provider_mailbox_read_summary_cmd "${provider}")" \
  MAILBOX_READ_CONTACT_CMD="$(provider_mailbox_read_contact_cmd "${provider}")" \
  python3 - <<'PY'
from pathlib import Path
import os

src = Path(os.environ["SRC"])
dst = Path(os.environ["DST"])
content = src.read_text()

for key in (
    "AGENT_NAME",
    "GOAL",
    "CREATED_AT",
    "CREATED_DATE",
    "RULES_FILENAME",
    "PROVIDER_SKILL_ROOT",
    "PROVIDER_SKILLS_DIR",
    "PROVIDER_AGENTS_DIR",
    "EPISODE_PLANNER_NAME",
    "EPISODE_EVALUATOR_NAME",
    "MAILBOX_READ_SUMMARY_CMD",
    "MAILBOX_READ_CONTACT_CMD",
):
    content = content.replace(f"{{{{{key}}}}}", os.environ[key])

dst.parent.mkdir(parents=True, exist_ok=True)
dst.write_text(content)
PY
}

# Update a single file: render template -> compare -> overwrite if different
update_file() {
  local tmpl="$1"
  local dest="$2"
  local agent_name="$3"
  local rules_filename="$4"
  local provider="$5"

  local tmp_file
  tmp_file="$(mktemp)"
  trap "rm -f '${tmp_file}'" RETURN

  render_template "${tmpl}" "${tmp_file}" "${agent_name}" "${rules_filename}" "${provider}"

  if [[ -f "${dest}" ]]; then
    if diff -q "${tmp_file}" "${dest}" >/dev/null 2>&1; then
      return 0  # no change
    fi
  fi

  if [[ "${DRY_RUN}" == "1" ]]; then
    echo "  [would update] ${dest}"
  else
    cp "${tmp_file}" "${dest}"
    echo "  [updated] ${dest}"
  fi
  return 0
}

migrate_directory_rules_file() {
  local dir="$1"
  local rules_filename="$2"
  local legacy_path="${dir}/README.md"
  local provider_path="${dir}/${rules_filename}"

  if [[ -f "${legacy_path}" && ! -f "${provider_path}" ]]; then
    if [[ "${DRY_RUN}" == "1" ]]; then
      echo "  [would migrate] ${legacy_path} -> ${provider_path}"
    else
      mv "${legacy_path}" "${provider_path}"
      echo "  [migrated] ${legacy_path} -> ${provider_path}"
    fi
    return 0
  fi

  if [[ -f "${legacy_path}" && -f "${provider_path}" ]]; then
    echo "  [warning] both ${legacy_path} and ${provider_path} exist; leaving legacy file untouched"
  fi
}

# ── Core update logic for one agent ─────────────────────────────────

update_one_agent() {
  local dir="$1"

  if [[ ! -d "${dir}" ]]; then
    echo "ERROR: directory not found: ${dir}"
    return 1
  fi

  local provider
  provider="$(detect_provider "${dir}")"
  if [[ -z "${provider}" ]]; then
    echo "ERROR: cannot detect provider for ${dir}"
    return 1
  fi

  local agent_name
  agent_name="$(read_agent_name "${dir}")"

  local rules_filename
  rules_filename="$(provider_rules_filename "${provider}")"

  local skill_dir
  skill_dir="$(provider_skill_root "${provider}")"
  local agent_dir
  agent_dir="$(provider_agent_root "${provider}")"
  local provider_template_dir="${PROVIDER_TEMPLATE_ROOT}/${provider}"

  echo "Updating agent: ${agent_name} (${dir})"
  echo "  Provider: ${provider}"

  local knowledge_rules_path="${dir}/Memory/knowledge/${rules_filename}"
  local episodes_rules_path="${dir}/Memory/episodes/${rules_filename}"
  local tool_notes_rules_path="${dir}/tool-notes/${rules_filename}"
  local mailbox_rules_path="${dir}/mailbox/${rules_filename}"

  migrate_directory_rules_file "${dir}/Memory/knowledge" "${rules_filename}"
  migrate_directory_rules_file "${dir}/Memory/episodes" "${rules_filename}"
  migrate_directory_rules_file "${dir}/tool-notes" "${rules_filename}"
  migrate_directory_rules_file "${dir}/mailbox" "${rules_filename}"

  update_file "${SHARED_TEMPLATE_DIR}/knowledge-README.md.tmpl" \
    "${knowledge_rules_path}" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/episodes-README.md.tmpl" \
    "${episodes_rules_path}" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/tool-notes-README.md.tmpl" \
    "${tool_notes_rules_path}" "${agent_name}" "${rules_filename}" "${provider}"

  # ── Shared infrastructure files ──
  update_file "${SHARED_TEMPLATE_DIR}/mailbox_io.py.tmpl" \
    "${dir}/mailbox_io.py" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/mailbox_feishu_bridge.py.tmpl" \
    "${dir}/mailbox_feishu_bridge.py" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/web_ui_server.py.tmpl" \
    "${dir}/web_ui_server.py" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/stop-agent.sh.tmpl" \
    "${dir}/stop-agent.sh" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/status-agent.sh.tmpl" \
    "${dir}/status-agent.sh" "${agent_name}" "${rules_filename}" "${provider}"

  update_file "${SHARED_TEMPLATE_DIR}/mailbox_bridge.env.example.tmpl" \
    "${dir}/mailbox_bridge.env.example" "${agent_name}" "${rules_filename}" "${provider}"

  # ── Shared skills: auto-discover shared/skills/<skill-name>/ ──
  # Each skill syncs SKILL.md and every scripts/*.tmpl into the agent's
  # provider-specific skill root. Runtime/bootstrap_state.json is NOT
  # created here — for legacy agents absence means phase=done.
  local skill_src_dir skill_basename skill_dst_dir script_tmpl script_basename
  for skill_src_dir in "${SHARED_TEMPLATE_DIR}/skills/"*/; do
    [[ -d "${skill_src_dir}" ]] || continue
    skill_basename="$(basename "${skill_src_dir}")"
    skill_dst_dir="${dir}/${skill_dir}/skills/${skill_basename}"
    if [[ "${DRY_RUN}" == "0" ]]; then
      mkdir -p "${skill_dst_dir}"
    fi

    if [[ -f "${skill_src_dir}SKILL.md.tmpl" ]]; then
      update_file "${skill_src_dir}SKILL.md.tmpl" \
        "${skill_dst_dir}/SKILL.md" "${agent_name}" "${rules_filename}" "${provider}"
    fi

    if [[ -d "${skill_src_dir}scripts" ]]; then
      if [[ "${DRY_RUN}" == "0" ]]; then
        mkdir -p "${skill_dst_dir}/scripts"
      fi
      for script_tmpl in "${skill_src_dir}scripts/"*.tmpl; do
        [[ -f "${script_tmpl}" ]] || continue
        script_basename="$(basename "${script_tmpl}" .tmpl)"
        update_file "${script_tmpl}" \
          "${skill_dst_dir}/scripts/${script_basename}" "${agent_name}" "${rules_filename}" "${provider}"
        if [[ "${DRY_RUN}" == "0" ]]; then
          chmod +x "${skill_dst_dir}/scripts/${script_basename}" 2>/dev/null || true
        fi
      done
    fi
  done

  # Clean up legacy location: earlier deployments put bootstrap_state.py at
  # workdir root. It now lives inside the bootstrap-sdlc skill, so the root
  # copy is stale. Remove it so agents cannot accidentally invoke the old one.
  if [[ -f "${dir}/bootstrap_state.py" ]]; then
    if [[ "${DRY_RUN}" == "1" ]]; then
      echo "  [would remove legacy] ${dir}/bootstrap_state.py"
    else
      rm -f "${dir}/bootstrap_state.py"
      echo "  [removed legacy] ${dir}/bootstrap_state.py"
    fi
  fi

  # ── Mailbox migration: ensure new directory structure exists ──
  if [[ "${DRY_RUN}" == "0" ]]; then
    mkdir -p "${dir}/Runtime/pending_messages"
    mkdir -p "${dir}/Runtime/awaiting_reply"
    mkdir -p "${dir}/Runtime/mailbox_read_last_id"

    # Migrate MAILBOX.jsonl -> human.jsonl if needed
    if [[ -f "${dir}/mailbox/MAILBOX.jsonl" && ! -f "${dir}/mailbox/human.jsonl" ]]; then
      cp "${dir}/mailbox/MAILBOX.jsonl" "${dir}/mailbox/human.jsonl"
      echo "  [migrated] mailbox/MAILBOX.jsonl -> mailbox/human.jsonl"
    fi

    # Initialize contacts.json if missing
    if [[ ! -f "${dir}/mailbox/contacts.json" ]]; then
      local created_at
      created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      cat > "${dir}/mailbox/contacts.json" <<EOF_CONTACTS
{
  "human": {
    "type": "human",
    "mailbox_file": "human.jsonl",
    "connected_at": "${created_at}"
  }
}
EOF_CONTACTS
      echo "  [created] mailbox/contacts.json"
    fi

    # Migrate pending_human.json -> pending_messages/human.json
    if [[ -f "${dir}/Runtime/pending_human.json" ]]; then
      mv "${dir}/Runtime/pending_human.json" "${dir}/Runtime/pending_messages/human.json"
      echo "  [migrated] Runtime/pending_human.json -> Runtime/pending_messages/human.json"
    fi

    # Migrate awaiting_human -> awaiting_reply/human
    if [[ -f "${dir}/Runtime/awaiting_human" ]]; then
      mv "${dir}/Runtime/awaiting_human" "${dir}/Runtime/awaiting_reply/human"
      echo "  [migrated] Runtime/awaiting_human -> Runtime/awaiting_reply/human"
    fi

    # Migrate mailbox_read_human_last_id -> mailbox_read_last_id/human
    if [[ -f "${dir}/Runtime/mailbox_read_human_last_id" ]]; then
      mv "${dir}/Runtime/mailbox_read_human_last_id" "${dir}/Runtime/mailbox_read_last_id/human"
      echo "  [migrated] Runtime/mailbox_read_human_last_id -> Runtime/mailbox_read_last_id/human"
    fi

    # Update mailbox rules file
    update_file "${SHARED_TEMPLATE_DIR}/mailbox-README.md.tmpl" \
      "${mailbox_rules_path}" "${agent_name}" "${rules_filename}" "${provider}"
  fi

  # ── Provider-specific files ──
  if [[ "${provider}" == "codex" ]]; then
    update_file "${provider_template_dir}/run_codex.mjs.tmpl" \
      "${dir}/run_codex.mjs" "${agent_name}" "${rules_filename}" "${provider}"

    update_file "${provider_template_dir}/start-codex.sh.tmpl" \
      "${dir}/start-codex.sh" "${agent_name}" "${rules_filename}" "${provider}"

    update_file "${provider_template_dir}/package.json.tmpl" \
      "${dir}/package.json" "${agent_name}" "${rules_filename}" "${provider}"

    if [[ -d "${provider_template_dir}/agents" ]]; then
      mkdir -p "${dir}/${agent_dir}/agents"
      for agent_tmpl in "${provider_template_dir}/agents/"*.toml.tmpl; do
        [[ -f "${agent_tmpl}" ]] || continue
        local agent_basename
        agent_basename="$(basename "${agent_tmpl}" .tmpl)"
        update_file "${agent_tmpl}" \
          "${dir}/${agent_dir}/agents/${agent_basename}" "${agent_name}" "${rules_filename}" "${provider}"
      done
    fi
  else
    update_file "${provider_template_dir}/run_claude.py.tmpl" \
      "${dir}/run_claude.py" "${agent_name}" "${rules_filename}" "${provider}"

    update_file "${provider_template_dir}/start-claude.sh.tmpl" \
      "${dir}/start-claude.sh" "${agent_name}" "${rules_filename}" "${provider}"

    # Built-in agents (evaluator etc.)
    if [[ -d "${provider_template_dir}/agents" ]]; then
      mkdir -p "${dir}/${agent_dir}/agents"
      for agent_tmpl in "${provider_template_dir}/agents/"*.md.tmpl; do
        [[ -f "${agent_tmpl}" ]] || continue
        local agent_basename
        agent_basename="$(basename "${agent_tmpl}" .tmpl)"
        update_file "${agent_tmpl}" \
          "${dir}/${agent_dir}/agents/${agent_basename}" "${agent_name}" "${rules_filename}" "${provider}"
      done
    fi
  fi

  update_file "${provider_template_dir}/requirements.txt.tmpl" \
    "${dir}/requirements.txt" "${agent_name}" "${rules_filename}" "${provider}"

  # ── Fix permissions ──
  if [[ "${DRY_RUN}" == "0" ]]; then
    chmod +x "${dir}/stop-agent.sh" "${dir}/status-agent.sh" \
      "${dir}/web_ui_server.py" \
      2>/dev/null || true
    # Skill scripts are chmod'd inside the skill-update loop above.

    if [[ "${provider}" == "codex" ]]; then
      chmod +x "${dir}/run_codex.mjs" "${dir}/start-codex.sh" 2>/dev/null || true
    else
      chmod +x "${dir}/run_claude.py" "${dir}/start-claude.sh" 2>/dev/null || true
    fi
  fi

  # ── Reinstall deps if requirements changed ──
  if [[ "${DRY_RUN}" == "0" ]]; then
    (
      cd "${dir}"
      uv venv --allow-existing >/dev/null 2>&1
      uv pip install --python .venv/bin/python -r requirements.txt >/dev/null 2>&1
    )
    if [[ "${provider}" == "codex" ]]; then
      ( cd "${dir}" && npm install --no-fund --no-audit >/dev/null 2>&1 )
    fi
  fi

  # ── Restart if requested ──
  if [[ "${RESTART}" == "1" && "${DRY_RUN}" == "0" ]]; then
    echo "  Restarting agent..."
    local interval
    interval="$(cat "${dir}/Runtime/interval" 2>/dev/null || echo "20")"
    ( cd "${dir}" && ./stop-agent.sh >/dev/null 2>&1 || true )
    sleep 1
    if [[ "${provider}" == "codex" ]]; then
      ( cd "${dir}" && TASK_FORGE_SKIP_BRIDGE=1 ./start-codex.sh --interval "${interval}" >/dev/null )
    else
      ( cd "${dir}" && TASK_FORGE_SKIP_BRIDGE=1 ./start-claude.sh --interval "${interval}" >/dev/null )
    fi
    sleep 2
    local pid
    pid="$(cat "${dir}/Runtime/pid" 2>/dev/null || echo "")"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      echo "  Agent restarted (PID: ${pid})"
    else
      echo "  WARNING: Agent may have failed to restart. Check logs."
    fi
  fi

  echo "  Done."
}

# ── Main ─────────────────────────────────────────────────────────────

if [[ "${UPDATE_ALL}" == "1" && -n "${WORKDIR}" ]]; then
  echo "Error: --all and --workdir are mutually exclusive."
  exit 1
fi

if [[ "${UPDATE_ALL}" == "0" && -z "${WORKDIR}" ]]; then
  echo "Error: must specify --workdir or --all."
  usage
  exit 1
fi

if [[ "${DRY_RUN}" == "1" ]]; then
  echo "=== DRY RUN — no files will be modified ==="
  echo ""
fi

if [[ -n "${WORKDIR}" ]]; then
  WORKDIR="$(resolve_path "${WORKDIR}")"
  update_one_agent "${WORKDIR}"
elif [[ "${UPDATE_ALL}" == "1" ]]; then
  REGISTRY="${HOME}/.agent-platform/registry.json"
  if [[ ! -f "${REGISTRY}" ]]; then
    echo "No registry found at ${REGISTRY}. No agents to update."
    exit 0
  fi

  # Extract all workdirs from registry
  mapfile -t WORKDIRS < <(python3 -c "
import json, sys
data = json.load(open('${REGISTRY}'))
for agent in data.get('agents', {}).values():
    wd = agent.get('workdir', '')
    if wd:
        print(wd)
")

  if [[ ${#WORKDIRS[@]} -eq 0 ]]; then
    echo "No agents found in registry."
    exit 0
  fi

  echo "Found ${#WORKDIRS[@]} agent(s) to update."
  echo ""

  FAILED=0
  for wd in "${WORKDIRS[@]}"; do
    update_one_agent "${wd}" || FAILED=$((FAILED + 1))
    echo ""
  done

  if [[ "${FAILED}" -gt 0 ]]; then
    echo "${FAILED} agent(s) failed to update."
    exit 1
  fi

  echo "All agents updated successfully."
fi
