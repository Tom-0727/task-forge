#!/usr/bin/env python3
"""Bridge append-only mailbox messages to and from Feishu."""

from __future__ import annotations

import json
import os
import threading
import time
from datetime import datetime, timezone
from pathlib import Path

import lark_oapi as lark
from dotenv import load_dotenv
from lark_oapi.api.im.v1 import (
    CreateMessageRequest,
    CreateMessageRequestBody,
    P2ImMessageMessageReadV1,
    P2ImMessageReceiveV1,
)

from mailbox_io import append_message, mailbox_contains_field, messages_after_id

# ─── Paths ────────────────────────────────────────────────────────────

AGENT_DIR = Path(__file__).resolve().parent
MAILBOX = AGENT_DIR / "mailbox" / "MAILBOX.jsonl"
RUNTIME_DIR = AGENT_DIR / "Runtime"
STATE_FILE = RUNTIME_DIR / "bridge-state.json"
PENDING_HUMAN_FILE = RUNTIME_DIR / "pending_human.json"
STATE_LOCK = threading.Lock()

# ─── Environment ──────────────────────────────────────────────────────

load_dotenv(dotenv_path=AGENT_DIR / ".env", override=False)
load_dotenv(dotenv_path=AGENT_DIR / "mailbox_bridge.env", override=False)

APP_ID = os.environ["FEISHU_APP_ID"]
APP_SECRET = os.environ["FEISHU_APP_SECRET"]
CONFIGURED_CHAT_ID = os.getenv("FEISHU_CHAT_ID", "").strip()
OUTBOUND_TASK_PREFIX = os.getenv("FEISHU_OUTBOUND_TASK_PREFIX", "1").strip().lower() not in {
    "0",
    "false",
    "no",
    "off",
}
POLL_INTERVAL_SECONDS = max(1, int(os.getenv("FEISHU_MAILBOX_POLL_INTERVAL", "1")))
ALLOWED_USER_IDS: set[str] = {
    value.strip()
    for value in os.getenv("ALLOWED_USER_IDS", "").split(",")
    if value.strip()
}


def utcnow() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def log(message: str) -> None:
    print(f"[{utcnow()}] [mailbox-feishu-bridge] {message}", flush=True)


def load_state() -> dict:
    with STATE_LOCK:
        if not STATE_FILE.exists():
            return {"chat_id": "", "last_outbound_mailbox_id": "", "recent_inbound_feishu_message_ids": []}
        try:
            data = json.loads(STATE_FILE.read_text(encoding="utf-8"))
        except Exception:
            return {"chat_id": "", "last_outbound_mailbox_id": "", "recent_inbound_feishu_message_ids": []}

        if not isinstance(data, dict):
            return {"chat_id": "", "last_outbound_mailbox_id": "", "recent_inbound_feishu_message_ids": []}

        data.setdefault("chat_id", "")
        data.setdefault("last_outbound_mailbox_id", "")
        data.setdefault("recent_inbound_feishu_message_ids", [])
        return data


def save_state(state: dict) -> None:
    with STATE_LOCK:
        RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
        current = {"chat_id": "", "last_outbound_mailbox_id": "", "recent_inbound_feishu_message_ids": []}
        if STATE_FILE.exists():
            try:
                loaded = json.loads(STATE_FILE.read_text(encoding="utf-8"))
                if isinstance(loaded, dict):
                    current.update(loaded)
            except Exception:
                pass

        merged = dict(current)

        if state.get("chat_id"):
            merged["chat_id"] = state["chat_id"]

        current_last_id = str(current.get("last_outbound_mailbox_id", "") or "")
        new_last_id = str(state.get("last_outbound_mailbox_id", "") or "")
        merged["last_outbound_mailbox_id"] = max(current_last_id, new_last_id)

        recent: list[str] = []
        for source in (
            current.get("recent_inbound_feishu_message_ids", []),
            state.get("recent_inbound_feishu_message_ids", []),
        ):
            for value in source:
                if isinstance(value, str) and value not in recent:
                    recent.append(value)
        merged["recent_inbound_feishu_message_ids"] = recent[-200:]

        STATE_FILE.write_text(json.dumps(merged, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def resolve_chat_id(state: dict) -> str | None:
    if CONFIGURED_CHAT_ID:
        return CONFIGURED_CHAT_ID
    chat_id = state.get("chat_id")
    return chat_id or None


def remember_chat_id(state: dict, chat_id: str) -> None:
    if CONFIGURED_CHAT_ID:
        return
    if state.get("chat_id") == chat_id:
        return
    state["chat_id"] = chat_id
    save_state(state)
    log(f"Bound outbound Feishu chat to {chat_id}")


def record_recent_inbound_id(state: dict, message_id: str) -> None:
    recent = [value for value in state.get("recent_inbound_feishu_message_ids", []) if isinstance(value, str)]
    recent.append(message_id)
    state["recent_inbound_feishu_message_ids"] = recent[-200:]


def write_pending_human(entry: dict) -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "mailbox_id": entry["id"],
        "ts": entry["ts"],
        "source": "feishu",
        "feishu_message_id": entry.get("feishu_message_id"),
    }
    PENDING_HUMAN_FILE.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def format_outbound_text(entry: dict) -> str:
    message = str(entry.get("message", "")).strip()
    task_id = str(entry.get("task_id", "")).strip()

    if OUTBOUND_TASK_PREFIX and task_id:
        return f"[{{AGENT_NAME}} | {task_id}]\n{message}"
    return f"{{AGENT_NAME}}\n{message}"


def send_text(client: lark.Client, chat_id: str, text: str) -> None:
    req = (
        CreateMessageRequest.builder()
        .receive_id_type("chat_id")
        .request_body(
            CreateMessageRequestBody.builder()
            .receive_id(chat_id)
            .msg_type("text")
            .content(json.dumps({"text": text}, ensure_ascii=False))
            .build()
        )
        .build()
    )
    resp = client.im.v1.message.create(req)
    if not resp.success():
        raise RuntimeError(f"[send_text] error {resp.code}: {resp.msg}")


def outbound_worker(client: lark.Client) -> None:
    while True:
        try:
            state = load_state()
            chat_id = resolve_chat_id(state)
            if not chat_id:
                time.sleep(POLL_INTERVAL_SECONDS)
                continue

            last_id = state.get("last_outbound_mailbox_id") or None
            for entry in messages_after_id(MAILBOX, last_id, role="agent"):
                text = format_outbound_text(entry)
                send_text(client, chat_id, text)
                state["last_outbound_mailbox_id"] = entry["id"]
                save_state(state)
                log(f"Forwarded mailbox message {entry['id']} to Feishu")
        except Exception as exc:
            log(f"Outbound sync error: {exc}")

        time.sleep(POLL_INTERVAL_SECONDS)


def on_message(data: P2ImMessageReceiveV1) -> None:
    msg = data.event.message
    sender_id = data.event.sender.sender_id.open_id

    if msg.message_type != "text":
        return
    if ALLOWED_USER_IDS and sender_id not in ALLOWED_USER_IDS:
        return

    text = json.loads(msg.content).get("text", "").strip()
    if not text:
        return

    state = load_state()

    if CONFIGURED_CHAT_ID and msg.chat_id != CONFIGURED_CHAT_ID:
        log(f"Ignoring inbound message from unconfigured chat {msg.chat_id}")
        return

    recent_ids = {
        value
        for value in state.get("recent_inbound_feishu_message_ids", [])
        if isinstance(value, str)
    }
    if msg.message_id in recent_ids or mailbox_contains_field(MAILBOX, "feishu_message_id", msg.message_id):
        return

    entry = append_message(
        MAILBOX,
        role="human",
        task_id="task.human.reply",
        message=text,
        extra={
            "source": "feishu",
            "feishu_chat_id": msg.chat_id,
            "feishu_message_id": msg.message_id,
            "feishu_sender_id": sender_id,
        },
    )

    remember_chat_id(state, msg.chat_id)
    state = load_state()
    record_recent_inbound_id(state, msg.message_id)
    save_state(state)
    write_pending_human(entry)
    log(f"Recorded inbound Feishu message {msg.message_id} as mailbox entry {entry['id']}")


def on_message_read(_: P2ImMessageMessageReadV1) -> None:
    return


def main() -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)

    client = lark.Client.builder().app_id(APP_ID).app_secret(APP_SECRET).build()

    threading.Thread(target=outbound_worker, args=(client,), daemon=True).start()

    event_handler = (
        lark.EventDispatcherHandler.builder("", "")
        .register_p2_im_message_message_read_v1(on_message_read)
        .register_p2_im_message_receive_v1(on_message)
        .build()
    )

    log(f"Starting bridge for {{AGENT_NAME}}")
    ws = lark.ws.Client(
        APP_ID,
        APP_SECRET,
        event_handler=event_handler,
        log_level=lark.LogLevel.INFO,
    )
    ws.start()


if __name__ == "__main__":
    main()
