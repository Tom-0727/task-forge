#!/usr/bin/env bash

set -euo pipefail

AGENT_DIR="$(cd "$(dirname "$0")" && pwd)"
RUNTIME_DIR="${AGENT_DIR}/Runtime"
RUNNER_PID_FILE="${RUNTIME_DIR}/pid"
BRIDGE_PID_FILE="${RUNTIME_DIR}/bridge.pid"
WEB_UI_PID_FILE="${RUNTIME_DIR}/web_ui.pid"
PROVIDER_FILE="${RUNTIME_DIR}/runtime_provider"

is_running() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

read_pid() {
  local path="$1"
  if [[ -f "$path" ]]; then
    tr -d '[:space:]' < "$path"
  fi
}

stop_pid_file() {
  local label="$1"
  local path="$2"
  local pid

  pid="$(read_pid "$path")"
  if [[ -z "${pid}" ]]; then
    echo "${label} is not running."
    rm -f "$path"
    return
  fi

  if ! is_running "$pid"; then
    echo "${label} has a stale PID file (${pid}). Cleaning up."
    rm -f "$path"
    return
  fi

  echo "Stopping ${label} (PID ${pid})..."
  kill "$pid" 2>/dev/null || true

  for _ in $(seq 1 20); do
    if ! is_running "$pid"; then
      rm -f "$path"
      echo "${label} stopped."
      return
    fi
    sleep 0.5
  done

  echo "${label} did not stop gracefully. Sending SIGKILL."
  kill -9 "$pid" 2>/dev/null || true
  rm -f "$path"
}

stop_pid_file "runtime" "$RUNNER_PID_FILE"
stop_pid_file "Feishu bridge" "$BRIDGE_PID_FILE"
stop_pid_file "Web UI" "$WEB_UI_PID_FILE"

rm -f "$PROVIDER_FILE"

echo "Done."
