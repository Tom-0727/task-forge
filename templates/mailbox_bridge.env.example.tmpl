FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: lock the bridge to a single Feishu chat. Leave blank to bind to
# the first inbound chat that talks to this bridge.
FEISHU_CHAT_ID=

# Optional: comma-separated allowlist of Feishu open_id values.
ALLOWED_USER_IDS=

# Optional: react to each inbound Feishu text message with this emoji.
# Leave blank to disable. Default: OK
FEISHU_INBOUND_ACK_EMOJI=OK

# Optional: include task_id in outbound Feishu text. Default: 1
FEISHU_OUTBOUND_TASK_PREFIX=1

# Optional: outbound mailbox poll interval in seconds. Default: 1
FEISHU_MAILBOX_POLL_INTERVAL=1
