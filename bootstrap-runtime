#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SHARED_TEMPLATE_DIR="${SCRIPT_DIR}/shared"
PROVIDER_TEMPLATE_ROOT="${SCRIPT_DIR}/providers"

usage() {
  cat <<'USAGE'
Usage:
  ./bootstrap-runtime \
    --goal "Goal text" \
    --first-instruction "First instruction text" \
    --provider codex|claude \
    --interaction feishu|web-ui|platform \
    --interval 20 \
    --workdir /abs/path/to/runtime

Feishu mode only:
  --feishu-app-id xxx \
  --feishu-app-secret yyy \
  --feishu-chat-id oc_xxx

Web UI mode only:
  --web-ui-host 127.0.0.1 \
  --web-ui-port 8080

Example:
  ./bootstrap-runtime \
    --goal "Goal text" \
    --first-instruction "First instruction text" \
    --provider codex \
    --interaction feishu \
    --interval 20 \
    --workdir /abs/path/to/runtime \
    --feishu-app-id xxx \
    --feishu-app-secret yyy \
    --feishu-chat-id oc_xxx

Optional:
  --agent-name "ResearchBot"
  --goal-file /path/to/goal.txt
  --allowed-user-ids open_id_1,open_id_2
USAGE
}

GOAL=""
GOAL_FILE=""
FIRST_INSTRUCTION=""
PROVIDER=""
INTERACTION=""
INTERVAL=""
WORKDIR=""
AGENT_NAME=""
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_CHAT_ID=""
ALLOWED_USER_IDS=""
WEB_UI_HOST="127.0.0.1"
WEB_UI_PORT="8080"
RUNTIME_AGENT_NAME=""

resolve_path() {
  python3 - "$1" <<'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).expanduser().resolve())
PY
}

provider_rules_filename() {
  case "$1" in
    codex) echo "AGENTS.md" ;;
    claude) echo "CLAUDE.md" ;;
    *)
      echo "Error: unsupported provider for rules file: $1" >&2
      exit 1
      ;;
  esac
}

provider_skill_root() {
  case "$1" in
    codex) echo ".agents" ;;
    claude) echo ".claude" ;;
    *)
      echo "Error: unsupported provider for skill root: $1" >&2
      exit 1
      ;;
  esac
}

derive_agent_name() {
  local dir="$1"
  local name
  name="$(basename "$dir")"
  if [[ -z "$name" || "$name" == "/" || "$name" == "." ]]; then
    name="task-forge-agent"
  fi
  echo "$name"
}

infer_agent_name_from_rules_file() {
  local rules_file="$1"
  local first_line
  local name

  if [[ ! -f "${rules_file}" ]]; then
    return 1
  fi

  IFS= read -r first_line < "${rules_file}" || true
  if [[ "${first_line}" != \#* ]]; then
    return 1
  fi

  name="${first_line#\# }"
  name="${name% — Agent Behavioral Rules}"
  name="${name% - Agent Behavioral Rules}"
  if [[ -z "${name//[[:space:]]/}" ]]; then
    return 1
  fi

  echo "${name}"
}

infer_agent_name() {
  local dir="$1"
  local name

  if name="$(infer_agent_name_from_rules_file "${dir}/AGENTS.md")"; then
    echo "${name}"
    return 0
  fi

  if name="$(infer_agent_name_from_rules_file "${dir}/CLAUDE.md")"; then
    echo "${name}"
    return 0
  fi

  return 1
}

resolve_runtime_agent_name() {
  local runtime_name_file="${WORKDIR}/Runtime/agent_name"
  local name

  if [[ -f "${runtime_name_file}" ]]; then
    name="$(tr -d '\r' < "${runtime_name_file}")"
    if [[ -n "${name//[[:space:]]/}" ]]; then
      echo "${name}"
      return
    fi
  fi

  if name="$(infer_agent_name "${WORKDIR}")"; then
    echo "${name}"
    return
  fi

  echo "$(derive_agent_name "${WORKDIR}")"
}

write_runtime_agent_name() {
  local name="$1"
  mkdir -p "${WORKDIR}/Runtime"
  printf '%s\n' "${name}" > "${WORKDIR}/Runtime/agent_name"
}

write_runtime_goal() {
  mkdir -p "${WORKDIR}/Runtime"
  printf '%s\n' "${GOAL}" > "${WORKDIR}/Runtime/goal"
}

render_template() {
  local src="$1"
  local dst="$2"
  local agent_name="$3"
  local goal="$4"
  local created_at="$5"
  local created_date="$6"
  local rules_filename="$7"

  SRC="$src" \
  DST="$dst" \
  AGENT_NAME="$agent_name" \
  GOAL="$goal" \
  CREATED_AT="$created_at" \
  CREATED_DATE="$created_date" \
  RULES_FILENAME="$rules_filename" \
  PROVIDER_SKILL_DIR="$(provider_skill_root "${PROVIDER}")/skills" \
  python3 - <<'PY'
from pathlib import Path
import os

src = Path(os.environ["SRC"])
dst = Path(os.environ["DST"])
content = src.read_text()

for key in (
    "AGENT_NAME",
    "GOAL",
    "CREATED_AT",
    "CREATED_DATE",
    "RULES_FILENAME",
    "PROVIDER_SKILL_DIR",
):
    content = content.replace(f"{{{{{key}}}}}", os.environ[key])

dst.parent.mkdir(parents=True, exist_ok=True)
dst.write_text(content)
PY
}

ensure_template_sources() {
  local provider_template_dir="${PROVIDER_TEMPLATE_ROOT}/${PROVIDER}"

  if [[ ! -d "${SHARED_TEMPLATE_DIR}" ]]; then
    echo "Error: shared templates directory not found: ${SHARED_TEMPLATE_DIR}"
    exit 1
  fi

  if [[ ! -d "${provider_template_dir}" ]]; then
    echo "Error: provider templates directory not found: ${provider_template_dir}"
    exit 1
  fi

  local shared_required=(
    "agent-rules.md.tmpl"
    "knowledge-README.md.tmpl"
    "episodes-README.md.tmpl"
    "tool-notes-README.md.tmpl"
    "mailbox-README.md.tmpl"
    "MAILBOX.jsonl.tmpl"
    "mailbox_io.py.tmpl"
    "mailbox_feishu_bridge.py.tmpl"
    "web_ui_server.py.tmpl"
    "mailbox_bridge.env.example.tmpl"
    "stop-agent.sh.tmpl"
    "status-agent.sh.tmpl"
    "skills/mailbox-operate/SKILL.md.tmpl"
    "skills/mailbox-operate/scripts/send_mailbox.py.tmpl"
    "skills/mailbox-operate/scripts/read_mailbox.py.tmpl"
  )

  local provider_required=()
  if [[ "${PROVIDER}" == "codex" ]]; then
    provider_required=(
      "run_codex.mjs.tmpl"
      "start-codex.sh.tmpl"
      "package.json.tmpl"
      "requirements.txt.tmpl"
    )
  else
    provider_required=(
      "run_claude.py.tmpl"
      "start-claude.sh.tmpl"
      "requirements.txt.tmpl"
      "agents/evaluator.md.tmpl"
    )
  fi

  local rel
  for rel in "${shared_required[@]}"; do
    if [[ ! -f "${SHARED_TEMPLATE_DIR}/${rel}" ]]; then
      echo "Error: missing shared template: ${SHARED_TEMPLATE_DIR}/${rel}"
      exit 1
    fi
  done

  for rel in "${provider_required[@]}"; do
    if [[ ! -f "${provider_template_dir}/${rel}" ]]; then
      echo "Error: missing provider template: ${provider_template_dir}/${rel}"
      exit 1
    fi
  done
}

scaffold_workspace() {
  local agent_name="$1"
  local created_at
  local created_date
  local rules_filename
  local provider_template_dir="${PROVIDER_TEMPLATE_ROOT}/${PROVIDER}"
  local provider_skill_dir

  created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  created_date="$(date -u +%Y%m%dT%H%M%SZ)"
  rules_filename="$(provider_rules_filename "${PROVIDER}")"
  provider_skill_dir="$(provider_skill_root "${PROVIDER}")"

  mkdir -p "${WORKDIR}"
  mkdir -p "${WORKDIR}/Memory/knowledge/factual"
  mkdir -p "${WORKDIR}/Memory/knowledge/conceptual"
  mkdir -p "${WORKDIR}/Memory/knowledge/heuristic"
  mkdir -p "${WORKDIR}/Memory/knowledge/metacognitive"
  mkdir -p "${WORKDIR}/Memory/episodes"
  mkdir -p "${WORKDIR}/tool-notes"
  mkdir -p "${WORKDIR}/mailbox"
  mkdir -p "${WORKDIR}/Runtime"
  mkdir -p "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/scripts"
  mkdir -p "${WORKDIR}/${provider_skill_dir}/agents"

  render_template "${SHARED_TEMPLATE_DIR}/agent-rules.md.tmpl" \
    "${WORKDIR}/${rules_filename}" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  # Append provider-specific extra rules if the template exists
  local extra_rules_tmpl="${provider_template_dir}/extra-rules.md.tmpl"
  if [[ -f "${extra_rules_tmpl}" ]]; then
    local extra_rules_tmp="${WORKDIR}/${rules_filename}.extra.tmp"
    render_template "${extra_rules_tmpl}" \
      "${extra_rules_tmp}" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"
    cat "${extra_rules_tmp}" >> "${WORKDIR}/${rules_filename}"
    rm -f "${extra_rules_tmp}"
  fi

  render_template "${SHARED_TEMPLATE_DIR}/knowledge-README.md.tmpl" \
    "${WORKDIR}/Memory/knowledge/README.md" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/episodes-README.md.tmpl" \
    "${WORKDIR}/Memory/episodes/README.md" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/tool-notes-README.md.tmpl" \
    "${WORKDIR}/tool-notes/README.md" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/mailbox-README.md.tmpl" \
    "${WORKDIR}/mailbox/README.md" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/MAILBOX.jsonl.tmpl" \
    "${WORKDIR}/mailbox/MAILBOX.jsonl" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/mailbox_io.py.tmpl" \
    "${WORKDIR}/mailbox_io.py" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/mailbox_feishu_bridge.py.tmpl" \
    "${WORKDIR}/mailbox_feishu_bridge.py" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/web_ui_server.py.tmpl" \
    "${WORKDIR}/web_ui_server.py" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/mailbox_bridge.env.example.tmpl" \
    "${WORKDIR}/mailbox_bridge.env.example" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/stop-agent.sh.tmpl" \
    "${WORKDIR}/stop-agent.sh" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/status-agent.sh.tmpl" \
    "${WORKDIR}/status-agent.sh" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/skills/mailbox-operate/SKILL.md.tmpl" \
    "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/SKILL.md" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/skills/mailbox-operate/scripts/send_mailbox.py.tmpl" \
    "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/scripts/send_mailbox.py" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  render_template "${SHARED_TEMPLATE_DIR}/skills/mailbox-operate/scripts/read_mailbox.py.tmpl" \
    "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/scripts/read_mailbox.py" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  if [[ "${PROVIDER}" == "codex" ]]; then
    render_template "${provider_template_dir}/run_codex.mjs.tmpl" \
      "${WORKDIR}/run_codex.mjs" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

    render_template "${provider_template_dir}/start-codex.sh.tmpl" \
      "${WORKDIR}/start-codex.sh" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

    render_template "${provider_template_dir}/package.json.tmpl" \
      "${WORKDIR}/package.json" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"
  else
    render_template "${provider_template_dir}/run_claude.py.tmpl" \
      "${WORKDIR}/run_claude.py" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

    render_template "${provider_template_dir}/start-claude.sh.tmpl" \
      "${WORKDIR}/start-claude.sh" \
      "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

    if [[ -d "${provider_template_dir}/agents" ]]; then
      for agent_tmpl in "${provider_template_dir}/agents/"*.md.tmpl; do
        [[ -f "${agent_tmpl}" ]] || continue
        local agent_basename
        agent_basename="$(basename "${agent_tmpl}" .tmpl)"
        render_template "${agent_tmpl}" \
          "${WORKDIR}/${provider_skill_dir}/agents/${agent_basename}" \
          "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"
      done
    fi
  fi

  render_template "${provider_template_dir}/requirements.txt.tmpl" \
    "${WORKDIR}/requirements.txt" \
    "${agent_name}" "${GOAL}" "${created_at}" "${created_date}" "${rules_filename}"

  chmod +x "${WORKDIR}/web_ui_server.py"
  chmod +x "${WORKDIR}/stop-agent.sh"
  chmod +x "${WORKDIR}/status-agent.sh"
  chmod +x "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/scripts/send_mailbox.py"
  chmod +x "${WORKDIR}/${provider_skill_dir}/skills/mailbox-operate/scripts/read_mailbox.py"

  if [[ "${PROVIDER}" == "codex" ]]; then
    chmod +x "${WORKDIR}/run_codex.mjs"
    chmod +x "${WORKDIR}/start-codex.sh"
  else
    chmod +x "${WORKDIR}/run_claude.py"
    chmod +x "${WORKDIR}/start-claude.sh"
  fi
}

is_shared_workspace_layout() {
  local dir="$1"

  [[ -d "${dir}/mailbox" ]] &&
  [[ -f "${dir}/mailbox/MAILBOX.jsonl" ]] &&
  [[ -f "${dir}/mailbox_io.py" ]] &&
  [[ -f "${dir}/mailbox_feishu_bridge.py" ]] &&
  [[ -f "${dir}/web_ui_server.py" ]] &&
  [[ -x "${dir}/stop-agent.sh" ]] &&
  [[ -x "${dir}/status-agent.sh" ]] &&
  [[ -d "${dir}/Memory" ]] &&
  [[ -d "${dir}/tool-notes" ]]
}

is_provider_workspace_layout() {
  local dir="$1"

  if [[ "${PROVIDER}" == "codex" ]]; then
    [[ -f "${dir}/AGENTS.md" ]] &&
    [[ -f "${dir}/requirements.txt" ]] &&
    [[ -f "${dir}/package.json" ]] &&
    [[ -x "${dir}/start-codex.sh" ]] &&
    [[ -x "${dir}/run_codex.mjs" ]]
  else
    [[ -f "${dir}/requirements.txt" ]] &&
    [[ -x "${dir}/start-claude.sh" ]] &&
    [[ -x "${dir}/run_claude.py" ]] &&
    ([[ -f "${dir}/CLAUDE.md" ]] || [[ -f "${dir}/AGENTS.md" ]])
  fi
}

is_task_forge_workspace() {
  local dir="$1"
  is_shared_workspace_layout "${dir}" && is_provider_workspace_layout "${dir}"
}

write_feishu_env() {
  cat > "${WORKDIR}/mailbox_bridge.env" <<EOF_FEISHU
FEISHU_APP_ID=${FEISHU_APP_ID}
FEISHU_APP_SECRET=${FEISHU_APP_SECRET}
FEISHU_CHAT_ID=${FEISHU_CHAT_ID}
ALLOWED_USER_IDS=${ALLOWED_USER_IDS}
FEISHU_OUTBOUND_TASK_PREFIX=0
FEISHU_MAILBOX_POLL_INTERVAL=1
EOF_FEISHU
}

write_interaction_mode() {
  mkdir -p "${WORKDIR}/Runtime"
  printf '%s\n' "${INTERACTION}" > "${WORKDIR}/Runtime/interaction_mode"
}

ensure_workspace() {
  if [[ ! -e "${WORKDIR}" ]]; then
    local agent_name
    agent_name="${AGENT_NAME}"
    if [[ -z "${agent_name//[[:space:]]/}" ]]; then
      agent_name="$(derive_agent_name "${WORKDIR}")"
    fi

    scaffold_workspace "${agent_name}"
    RUNTIME_AGENT_NAME="${agent_name}"
    write_runtime_agent_name "${RUNTIME_AGENT_NAME}"
    return
  fi

  if ! is_task_forge_workspace "${WORKDIR}"; then
    echo "Error: ${WORKDIR} exists but is not a compatible task-forge workspace for provider '${PROVIDER}'."
    exit 1
  fi

  if [[ -n "${AGENT_NAME//[[:space:]]/}" ]]; then
    echo "Warning: --agent-name is ignored because workspace already exists."
  fi

  RUNTIME_AGENT_NAME="$(resolve_runtime_agent_name)"
  write_runtime_agent_name "${RUNTIME_AGENT_NAME}"
}

ensure_python_deps() {
  (
    cd "${WORKDIR}"
    uv venv --allow-existing >/dev/null
    uv pip install --python .venv/bin/python -r requirements.txt >/dev/null
  )
}

ensure_node_deps() {
  if [[ "${PROVIDER}" != "codex" ]]; then
    return
  fi

  (
    cd "${WORKDIR}"
    npm install --no-fund --no-audit >/dev/null
  )
}

seed_initial_instruction() {
  local result
  result="$(
    WORKDIR="${WORKDIR}" FIRST_INSTRUCTION="${FIRST_INSTRUCTION}" uv run --no-project --python "${WORKDIR}/.venv/bin/python" - <<'PY'
from pathlib import Path
import os
import sys

root = Path(os.environ["WORKDIR"])
first_instruction = os.environ["FIRST_INSTRUCTION"].strip()

sys.path.insert(0, str(root))
from mailbox_io import append_message, read_messages

mailbox_path = root / "mailbox" / "MAILBOX.jsonl"
messages = read_messages(mailbox_path)
has_user_goal = any(
    msg.get("role") == "human" and msg.get("task_id") != "task.system.init"
    for msg in messages
)

if has_user_goal:
    print("skipped")
else:
    append_message(
        mailbox_path,
        role="human",
        task_id="task.user.initial_instruction",
        message=first_instruction,
    )
    print("seeded")
PY
  )"

  echo "${result}"
}

read_pid_file() {
  local path="$1"
  if [[ -f "${path}" ]]; then
    tr -d '[:space:]' < "${path}"
  fi
}

is_running() {
  local pid="$1"
  kill -0 "${pid}" 2>/dev/null
}

ensure_started() {
  local runner_pid

  runner_pid="$(read_pid_file "${WORKDIR}/Runtime/pid")"

  if [[ -z "${runner_pid}" ]] || ! is_running "${runner_pid}"; then
    echo "Error: runtime failed to stay up."
    echo "Check: ${WORKDIR}/Runtime/${PROVIDER}.log"
    exit 1
  fi

  if [[ "${INTERACTION}" == "feishu" || ( "${INTERACTION}" == "platform" && -n "${FEISHU_APP_ID}" ) ]]; then
    local bridge_pid
    bridge_pid="$(read_pid_file "${WORKDIR}/Runtime/bridge.pid")"
    if [[ -z "${bridge_pid}" ]] || ! is_running "${bridge_pid}"; then
      echo "Error: Feishu bridge failed to stay up."
      echo "Check: ${WORKDIR}/Runtime/mailbox-feishu-bridge.log"
      exit 1
    fi
  fi

  if [[ "${INTERACTION}" == "web-ui" ]]; then
    local web_ui_pid
    web_ui_pid="$(read_pid_file "${WORKDIR}/Runtime/web_ui.pid")"
    if [[ -z "${web_ui_pid}" ]] || ! is_running "${web_ui_pid}"; then
      echo "Error: Web UI failed to stay up."
      echo "Check: ${WORKDIR}/Runtime/web-ui.log"
      exit 1
    fi
  fi
}

start_web_ui() {
  local web_ui_pid
  local web_ui_pid_file="${WORKDIR}/Runtime/web_ui.pid"
  local web_ui_log="${WORKDIR}/Runtime/web-ui.log"
  local python_bin="${WORKDIR}/.venv/bin/python"
  local web_ui_script="${WORKDIR}/web_ui_server.py"

  if [[ ! -f "${web_ui_script}" ]]; then
    echo "Error: ${web_ui_script} is missing in this workspace."
    echo "Recreate workspace with the latest shared/provider templates."
    exit 1
  fi

  web_ui_pid="$(read_pid_file "${web_ui_pid_file}")"
  if [[ -n "${web_ui_pid}" ]] && is_running "${web_ui_pid}"; then
    return
  fi

  rm -f "${web_ui_pid_file}"
  nohup uv run --no-project --python "${python_bin}" "${web_ui_script}" --host "${WEB_UI_HOST}" --port "${WEB_UI_PORT}" >"${web_ui_log}" 2>&1 &
  web_ui_pid="$!"
  echo "${web_ui_pid}" > "${web_ui_pid_file}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --goal)
      GOAL="$2"
      shift 2
      ;;
    --first-instruction)
      FIRST_INSTRUCTION="$2"
      shift 2
      ;;
    --goal-file)
      GOAL_FILE="$2"
      shift 2
      ;;
    --provider)
      PROVIDER="$2"
      shift 2
      ;;
    --interaction)
      INTERACTION="$2"
      shift 2
      ;;
    --interval)
      INTERVAL="$2"
      shift 2
      ;;
    --workdir)
      WORKDIR="$2"
      shift 2
      ;;
    --agent-name)
      AGENT_NAME="$2"
      shift 2
      ;;
    --feishu-app-id)
      FEISHU_APP_ID="$2"
      shift 2
      ;;
    --feishu-app-secret)
      FEISHU_APP_SECRET="$2"
      shift 2
      ;;
    --feishu-chat-id)
      FEISHU_CHAT_ID="$2"
      shift 2
      ;;
    --allowed-user-ids)
      ALLOWED_USER_IDS="$2"
      shift 2
      ;;
    --web-ui-host)
      WEB_UI_HOST="$2"
      shift 2
      ;;
    --web-ui-port)
      WEB_UI_PORT="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ -n "${GOAL_FILE}" ]]; then
  if [[ ! -f "${GOAL_FILE}" ]]; then
    echo "Error: goal file not found: ${GOAL_FILE}"
    exit 1
  fi
  GOAL="$(< "${GOAL_FILE}")"
fi

if [[ -z "${GOAL//[[:space:]]/}" ]]; then
  echo "Error: --goal or --goal-file is required."
  exit 1
fi

if [[ -z "${FIRST_INSTRUCTION//[[:space:]]/}" ]]; then
  echo "Error: --first-instruction is required."
  exit 1
fi

if [[ "${PROVIDER}" != "codex" && "${PROVIDER}" != "claude" ]]; then
  echo "Error: --provider must be codex or claude."
  exit 1
fi

if [[ "${INTERACTION}" != "feishu" && "${INTERACTION}" != "web-ui" && "${INTERACTION}" != "platform" ]]; then
  echo "Error: --interaction must be feishu, web-ui, or platform."
  exit 1
fi

if ! [[ "${INTERVAL}" =~ ^[0-9]+$ ]]; then
  echo "Error: --interval must be a non-negative integer."
  exit 1
fi

if [[ -z "${WORKDIR}" ]]; then
  echo "Error: --workdir is required."
  exit 1
fi

if [[ -n "${AGENT_NAME}" && -z "${AGENT_NAME//[[:space:]]/}" ]]; then
  echo "Error: --agent-name cannot be empty."
  exit 1
fi

if [[ "${INTERACTION}" == "feishu" ]]; then
  if [[ -z "${FEISHU_APP_ID}" || -z "${FEISHU_APP_SECRET}" || -z "${FEISHU_CHAT_ID}" ]]; then
    echo "Error: Feishu mode requires --feishu-app-id, --feishu-app-secret, --feishu-chat-id."
    exit 1
  fi
elif [[ "${INTERACTION}" == "web-ui" ]]; then
  if [[ -n "${FEISHU_APP_ID}" || -n "${FEISHU_APP_SECRET}" || -n "${FEISHU_CHAT_ID}" || -n "${ALLOWED_USER_IDS}" ]]; then
    echo "Error: Web UI mode must not include Feishu arguments."
    exit 1
  fi
fi
# platform mode: feishu args are optional (bridge started if provided)

if ! [[ "${WEB_UI_PORT}" =~ ^[0-9]+$ ]] || [[ "${WEB_UI_PORT}" -le 0 ]] || [[ "${WEB_UI_PORT}" -gt 65535 ]]; then
  echo "Error: --web-ui-port must be an integer between 1 and 65535."
  exit 1
fi

WORKDIR="$(resolve_path "${WORKDIR}")"

ensure_template_sources
ensure_workspace
write_runtime_goal
if [[ "${INTERACTION}" == "feishu" ]]; then
  write_feishu_env
elif [[ "${INTERACTION}" == "platform" && -n "${FEISHU_APP_ID}" ]]; then
  write_feishu_env
fi
write_interaction_mode
ensure_python_deps
ensure_node_deps

GOAL_STATUS="$(seed_initial_instruction)"

# Determine whether to skip the feishu bridge
SKIP_BRIDGE=0
if [[ "${INTERACTION}" == "web-ui" ]]; then
  SKIP_BRIDGE=1
elif [[ "${INTERACTION}" == "platform" && -z "${FEISHU_APP_ID}" ]]; then
  SKIP_BRIDGE=1
fi

(
  cd "${WORKDIR}"
  ./stop-agent.sh >/dev/null 2>&1 || true
  if [[ "${PROVIDER}" == "codex" ]]; then
    if [[ "${SKIP_BRIDGE}" == "1" ]]; then
      TASK_FORGE_SKIP_BRIDGE=1 ./start-codex.sh --interval "${INTERVAL}" >/dev/null
    else
      ./start-codex.sh --interval "${INTERVAL}" >/dev/null
    fi
  else
    if [[ "${SKIP_BRIDGE}" == "1" ]]; then
      TASK_FORGE_SKIP_BRIDGE=1 ./start-claude.sh --interval "${INTERVAL}" >/dev/null
    else
      ./start-claude.sh --interval "${INTERVAL}" >/dev/null
    fi
  fi
)

if [[ "${INTERACTION}" == "web-ui" ]]; then
  start_web_ui
fi

sleep 2
ensure_started

echo "Runtime ready"
echo "Workdir: ${WORKDIR}"
echo "Agent name: ${RUNTIME_AGENT_NAME}"
echo "Provider: ${PROVIDER}"
echo "Interaction: ${INTERACTION}"
echo "Interval: ${INTERVAL}"
echo "Initial instruction seeded: ${GOAL_STATUS}"
echo "Runner PID: $(read_pid_file "${WORKDIR}/Runtime/pid")"
if [[ "${INTERACTION}" == "feishu" || ( "${INTERACTION}" == "platform" && -n "${FEISHU_APP_ID}" ) ]]; then
  echo "Bridge PID: $(read_pid_file "${WORKDIR}/Runtime/bridge.pid")"
fi
if [[ "${INTERACTION}" == "web-ui" ]]; then
  echo "Web UI PID: $(read_pid_file "${WORKDIR}/Runtime/web_ui.pid")"
  echo "Web UI URL: http://${WEB_UI_HOST}:${WEB_UI_PORT}"
fi
