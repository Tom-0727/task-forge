#!/usr/bin/env python3
"""Deploy (or redeploy) a long-run agent workspace as a thin shim over the central engine.

The workspace holds only identity, memory, mailbox, and per-agent subagent/skill
references. All runtime code lives under engine/. Shared skills are symlinked
from engine/skills/<name> into .claude/skills/<name> (claude) or
.agents/skills/<name> (codex) based on engine/skills/default.json.
"""
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
ENGINE_ROOT = REPO_ROOT / "engine"
TEMPLATE_DIR = ENGINE_ROOT / "templates"
ENGINE_SKILLS_DIR = ENGINE_ROOT / "skills"
SKILL_DEFAULTS_FILE = ENGINE_SKILLS_DIR / "default.json"

PROVIDER_CONFIG = {
    "claude": {
        "rules_filename": "CLAUDE.md",
        "rules_tmpl": "CLAUDE.md.tmpl",
        "skill_root": ".claude/skills",
        "subagent_root": ".claude/agents",
        "subagent_dir": "agents/claude",
        "subagent_suffix": ".md",
        "episode_planner_name": "episode-planner",
        "episode_evaluator_name": "episode-evaluator",
    },
    "codex": {
        "rules_filename": "AGENTS.md",
        "rules_tmpl": "AGENTS.md.tmpl",
        "skill_root": ".agents/skills",
        "subagent_root": ".codex/agents",
        "subagent_dir": "agents/codex",
        "subagent_suffix": ".toml",
        "episode_planner_name": "episode_planner",
        "episode_evaluator_name": "episode_evaluator",
    },
}


def utcnow_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def utcnow_compact() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def render(tmpl_path: Path, replacements: dict[str, str]) -> str:
    content = tmpl_path.read_text(encoding="utf-8")
    for key, value in replacements.items():
        content = content.replace("{{" + key + "}}", value)
    return content


def write(dst: Path, content: str, executable: bool = False) -> None:
    dst.parent.mkdir(parents=True, exist_ok=True)
    dst.write_text(content, encoding="utf-8")
    if executable:
        dst.chmod(0o755)


def load_engine_version() -> str:
    pkg = json.loads((ENGINE_ROOT / "package.json").read_text(encoding="utf-8"))
    return pkg.get("version", "0.0.0")


def load_default_skills(provider: str) -> list[str]:
    defaults = json.loads(SKILL_DEFAULTS_FILE.read_text(encoding="utf-8"))
    return defaults.get(provider, [])


def link_default_skills(workdir: Path, provider: str) -> None:
    cfg = PROVIDER_CONFIG[provider]
    skills_parent = workdir / cfg["skill_root"]
    skills_parent.mkdir(parents=True, exist_ok=True)
    for skill_name in load_default_skills(provider):
        src = ENGINE_SKILLS_DIR / skill_name
        if not src.exists():
            raise SystemExit(f"engine skill not found: {src}")
        dst = skills_parent / skill_name
        if dst.is_symlink() or dst.exists():
            if dst.is_symlink() and Path(os.readlink(dst)) == src:
                continue
            if dst.is_symlink() or dst.is_file():
                dst.unlink()
            else:
                shutil.rmtree(dst)
        dst.symlink_to(src)


def render_subagents(workdir: Path, provider: str, replacements: dict[str, str]) -> None:
    cfg = PROVIDER_CONFIG[provider]
    src_dir = TEMPLATE_DIR / cfg["subagent_dir"]
    dst_dir = workdir / cfg["subagent_root"]
    dst_dir.mkdir(parents=True, exist_ok=True)
    suffix = cfg["subagent_suffix"] + ".tmpl"
    for tmpl in sorted(src_dir.glob(f"*{suffix}")):
        body = render(tmpl, replacements)
        dst = dst_dir / tmpl.name[: -len(".tmpl")]
        write(dst, body)


def write_agent_json(
    workdir: Path,
    agent_name: str,
    provider: str,
    interaction_mode: str,
    web_ui_port: int | None,
    feishu: dict | None,
    interval: int,
    engine_version: str,
) -> None:
    runtime_dir = workdir / "Runtime"
    runtime_dir.mkdir(parents=True, exist_ok=True)
    interaction: dict = {"mode": interaction_mode}
    if web_ui_port is not None:
        interaction["web_ui_port"] = web_ui_port
    if feishu is not None:
        interaction["feishu"] = feishu
    identity = {
        "schema_version": 1,
        "agent_name": agent_name,
        "provider": provider,
        "created_at": utcnow_iso(),
        "engine_version_at_create": engine_version,
        "interaction": interaction,
        "runtime": {
            "default_interval_minutes": interval,
            "default_max_turns": 400,
            "default_max_budget_usd": 5.0,
        },
    }
    (runtime_dir / "agent.json").write_text(
        json.dumps(identity, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


def seed_mailbox(workdir: Path, agent_name: str, created_at: str, created_date: str,
                 first_instruction: str, rules_filename: str) -> None:
    mailbox = workdir / "mailbox"
    mailbox.mkdir(parents=True, exist_ok=True)
    contacts_file = mailbox / "contacts.json"
    if not contacts_file.exists():
        contacts_file.write_text(
            json.dumps(
                {"human": {"type": "human", "mailbox_file": "human.jsonl", "connected_at": created_at}},
                indent=2,
                ensure_ascii=False,
            ) + "\n",
            encoding="utf-8",
        )
    human_mb = mailbox / "human.jsonl"
    existing = human_mb.read_text(encoding="utf-8") if human_mb.exists() else ""
    lines = [ln for ln in existing.splitlines() if ln.strip()]
    has_init = any('"task.system.init"' in ln for ln in lines)
    has_user_goal = any(
        '"task.system.init"' not in ln and '"from":"human"' in ln.replace(" ", "")
        for ln in lines
    )
    new_lines = list(lines)
    if not has_init:
        init = {
            "id": f"mail.{created_date}.000",
            "ts": created_at,
            "from": "human",
            "to": agent_name,
            "task_id": "task.system.init",
            "message": f"{agent_name} initialized. Welcome. Read {rules_filename} for your behavioral rules and begin working.",
        }
        new_lines.append(json.dumps(init, ensure_ascii=False))
    if not has_user_goal and first_instruction.strip():
        instr = {
            "id": f"mail.{created_date}.001",
            "ts": created_at,
            "from": "human",
            "to": agent_name,
            "task_id": "task.user.initial_instruction",
            "message": first_instruction.strip(),
        }
        new_lines.append(json.dumps(instr, ensure_ascii=False))
    human_mb.write_text("\n".join(new_lines) + ("\n" if new_lines else ""), encoding="utf-8")


def seed_bootstrap_state(workdir: Path, created_at: str) -> None:
    dst = workdir / "Runtime" / "bootstrap_state.json"
    if dst.exists():
        return
    dst.write_text(
        json.dumps(
            {
                "phase": "prd",
                "prd_path": "Memory/knowledge/conceptual/conceptual--bootstrap--prd.md",
                "architecture_path": "Memory/knowledge/conceptual/conceptual--bootstrap--architecture.md",
                "assumptions_path": "Memory/knowledge/conceptual/conceptual--bootstrap--assumptions.md",
                "created_at": created_at,
                "phase_history": [
                    {"phase": "prd", "entered_at": created_at, "note": "initial bootstrap"}
                ],
            },
            indent=2,
            ensure_ascii=False,
        ) + "\n",
        encoding="utf-8",
    )


def write_feishu_env(workdir: Path, feishu_app_id: str, feishu_app_secret: str,
                     feishu_chat_id: str, allowed_user_ids: str) -> None:
    (workdir / "mailbox_bridge.env").write_text(
        f"FEISHU_APP_ID={feishu_app_id}\n"
        f"FEISHU_APP_SECRET={feishu_app_secret}\n"
        f"FEISHU_CHAT_ID={feishu_chat_id}\n"
        f"ALLOWED_USER_IDS={allowed_user_ids}\n"
        "FEISHU_OUTBOUND_TASK_PREFIX=0\n"
        "FEISHU_MAILBOX_POLL_INTERVAL=1\n",
        encoding="utf-8",
    )


def scaffold_workspace(workdir: Path, agent_name: str, goal: str, provider: str) -> None:
    cfg = PROVIDER_CONFIG[provider]
    created_at = utcnow_iso()
    created_date = utcnow_compact()
    replacements = {
        "AGENT_NAME": agent_name,
        "GOAL": goal,
        "CREATED_AT": created_at,
        "CREATED_DATE": created_date,
        "EPISODE_PLANNER_NAME": cfg["episode_planner_name"],
        "EPISODE_EVALUATOR_NAME": cfg["episode_evaluator_name"],
    }

    for sub in (
        "Memory/knowledge/factual",
        "Memory/knowledge/conceptual",
        "Memory/knowledge/heuristic",
        "Memory/knowledge/metacognitive",
        "Memory/episodes",
        "tool-notes",
        "Runtime/pending_messages",
        "Runtime/awaiting_reply",
        "Runtime/pids",
        "Runtime/logs",
        "Runtime/mailbox_read_last_id",
    ):
        (workdir / sub).mkdir(parents=True, exist_ok=True)

    write(workdir / cfg["rules_filename"],
          render(TEMPLATE_DIR / cfg["rules_tmpl"], replacements))

    write(workdir / "Memory" / "knowledge" / "README.md",
          render(TEMPLATE_DIR / "knowledge-README.md.tmpl", replacements))
    write(workdir / "Memory" / "episodes" / "README.md",
          render(TEMPLATE_DIR / "episodes-README.md.tmpl", replacements))
    write(workdir / "tool-notes" / "README.md",
          render(TEMPLATE_DIR / "tool-notes-README.md.tmpl", replacements))
    write(workdir / "mailbox" / "README.md",
          render(TEMPLATE_DIR / "mailbox-README.md.tmpl", replacements))

    link_default_skills(workdir, provider)
    render_subagents(workdir, provider, replacements)
    seed_bootstrap_state(workdir, created_at)

    return created_at, created_date


def resolve_interaction(raw: str, feishu_app_id: str) -> tuple[str, dict | None]:
    if raw == "platform":
        if feishu_app_id:
            return "feishu", None
        return "none", None
    return raw, None


def main() -> int:
    ap = argparse.ArgumentParser(description="Deploy a long-run agent shim workspace.")
    ap.add_argument("--goal")
    ap.add_argument("--goal-file")
    ap.add_argument("--first-instruction", required=True)
    ap.add_argument("--provider", choices=["claude", "codex"], required=True)
    ap.add_argument(
        "--interaction",
        choices=["feishu", "web-ui", "platform", "none"],
        required=True,
        help="platform is a compatibility alias: maps to feishu if feishu creds given, else none.",
    )
    ap.add_argument("--interval", type=int, required=True)
    ap.add_argument("--workdir", required=True)
    ap.add_argument("--agent-name")
    ap.add_argument("--feishu-app-id", default="")
    ap.add_argument("--feishu-app-secret", default="")
    ap.add_argument("--feishu-chat-id", default="")
    ap.add_argument("--allowed-user-ids", default="")
    ap.add_argument("--web-ui-port", type=int, default=8080)
    ap.add_argument("--no-start", action="store_true", help="scaffold only; do not launch supervisor.")
    args = ap.parse_args()

    goal = args.goal or ""
    if args.goal_file:
        goal = Path(args.goal_file).expanduser().read_text(encoding="utf-8")
    if not goal.strip():
        ap.error("--goal or --goal-file required")
    if args.interval < 0:
        ap.error("--interval must be non-negative")
    if args.interaction == "feishu":
        if not (args.feishu_app_id and args.feishu_app_secret and args.feishu_chat_id):
            ap.error("feishu mode requires --feishu-app-id/--feishu-app-secret/--feishu-chat-id")

    workdir = Path(args.workdir).expanduser().resolve()
    workdir.mkdir(parents=True, exist_ok=True)

    agent_name = (args.agent_name or workdir.name).strip()
    if not agent_name:
        ap.error("derived agent name is empty")

    interaction_mode, _ = resolve_interaction(args.interaction, args.feishu_app_id)
    if interaction_mode == "feishu" and not args.feishu_app_id:
        ap.error("resolved interaction=feishu but no feishu credentials given")

    created_at, _ = scaffold_workspace(workdir, agent_name, goal, args.provider)
    rules_filename = PROVIDER_CONFIG[args.provider]["rules_filename"]
    seed_mailbox(workdir, agent_name, created_at, utcnow_compact(),
                 args.first_instruction, rules_filename)
    (workdir / "Runtime" / "goal").write_text(goal.rstrip() + "\n", encoding="utf-8")

    feishu_cfg = None
    web_ui_port = None
    if interaction_mode == "feishu":
        feishu_cfg = {
            "app_id_env": "FEISHU_APP_ID",
            "app_secret_env": "FEISHU_APP_SECRET",
            "chat_id": args.feishu_chat_id,
        }
        write_feishu_env(workdir, args.feishu_app_id, args.feishu_app_secret,
                         args.feishu_chat_id, args.allowed_user_ids)
    if interaction_mode == "web-ui":
        web_ui_port = args.web_ui_port

    write_agent_json(
        workdir=workdir,
        agent_name=agent_name,
        provider=args.provider,
        interaction_mode=interaction_mode,
        web_ui_port=web_ui_port,
        feishu=feishu_cfg,
        interval=args.interval,
        engine_version=load_engine_version(),
    )

    print(f"[deploy-agent] scaffolded {workdir}")
    print(f"  agent_name    : {agent_name}")
    print(f"  provider      : {args.provider}")
    print(f"  interaction   : {interaction_mode}")
    print(f"  interval      : {args.interval}m")

    if args.no_start:
        print("[deploy-agent] --no-start: skipping supervisor launch")
        return 0

    subprocess.check_call([str(ENGINE_ROOT / "bin" / "stop.sh"), "--agent-dir", str(workdir)],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    log_file = workdir / "Runtime" / "logs" / "start.log"
    log_file.parent.mkdir(parents=True, exist_ok=True)
    with log_file.open("a", encoding="utf-8") as lf:
        subprocess.Popen(
            [str(ENGINE_ROOT / "bin" / "start.sh"), "--agent-dir", str(workdir)],
            stdout=lf, stderr=subprocess.STDOUT, start_new_session=True,
        )
    print(f"[deploy-agent] launched supervisor in background (log: {log_file})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
