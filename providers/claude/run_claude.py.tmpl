#!/usr/bin/env python3
"""run_claude.py — Claude heartbeat launcher for {{AGENT_NAME}}

Created: {{CREATED_AT}}

Usage:
    uv run python run_claude.py [--interval N] [--max-turns N] [--max-budget USD]

Options:
    --interval     Heartbeat interval in minutes (default: 20)
    --max-turns    Max agent turns per heartbeat (default: 50)
    --max-budget   Max USD budget per heartbeat (default: 5.0)
"""

import argparse
import asyncio
import json
import os
import signal
import sys
from datetime import datetime, timezone
from pathlib import Path

from claude_agent_sdk import ClaudeAgentOptions, ResultMessage, AssistantMessage, RateLimitEvent, query

# ─── Paths ────────────────────────────────────────────────────────────

AGENT_DIR = Path(__file__).resolve().parent
RUNTIME_DIR = AGENT_DIR / "Runtime"
MAILBOX = AGENT_DIR / "mailbox" / "MAILBOX.jsonl"
PID_FILE = RUNTIME_DIR / "pid"
HEARTBEAT_FILE = RUNTIME_DIR / "last_heartbeat"
STATE_FILE = RUNTIME_DIR / "state"
PROVIDER_FILE = RUNTIME_DIR / "runtime_provider"
SESSION_FILE = RUNTIME_DIR / "claude_session_id"
LEGACY_SESSION_FILE = RUNTIME_DIR / "session_id"
AWAITING_FILE = RUNTIME_DIR / "awaiting_human"
PENDING_HUMAN_FILE = RUNTIME_DIR / "pending_human.json"
RATELIMIT_FILE = RUNTIME_DIR / "ratelimit.json"
INTERVAL_FILE = RUNTIME_DIR / "interval"
WORK_SCHEDULE_FILE = RUNTIME_DIR / "work_schedule.json"

# ─── Globals ──────────────────────────────────────────────────────────

shutdown_requested = False


def utcnow() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def log(msg: str):
    print(f"[{utcnow()}] {msg}", flush=True)


# ─── Signal handling ──────────────────────────────────────────────────

def handle_signal(signum, frame):
    global shutdown_requested
    log(f"Received signal {signum}. Shutting down {{AGENT_NAME}}...")
    shutdown_requested = True


signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)


# ─── PID management ──────────────────────────────────────────────────

def check_and_write_pid():
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)

    if PID_FILE.exists():
        try:
            old_pid = int(PID_FILE.read_text().strip())
        except ValueError:
            log("Invalid PID file found. Cleaning up.")
            PID_FILE.unlink(missing_ok=True)
            old_pid = None
        if old_pid is None:
            pass
        else:
            try:
                os.kill(old_pid, 0)
                provider = PROVIDER_FILE.read_text().strip() if PROVIDER_FILE.exists() else "unknown"
                print(f"Error: {{AGENT_NAME}} runtime is already running ({provider}, PID {old_pid})")
                sys.exit(1)
            except OSError:
                log(f"Stale PID file found (PID {old_pid} not running). Cleaning up.")
                PID_FILE.unlink()
                PROVIDER_FILE.unlink(missing_ok=True)

    PID_FILE.write_text(str(os.getpid()))
    PROVIDER_FILE.write_text("claude")


def cleanup_pid():
    PID_FILE.unlink(missing_ok=True)
    PROVIDER_FILE.unlink(missing_ok=True)
    STATE_FILE.write_text("stopped")


# ─── Mailbox helpers ─────────────────────────────────────────────────

def has_new_human_messages() -> bool:
    if not MAILBOX.exists():
        return False

    last_agent_line = -1
    last_human_line = -1

    for i, line in enumerate(MAILBOX.read_text().splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue
        if msg.get("role") == "agent":
            last_agent_line = i
        elif msg.get("role") == "human":
            last_human_line = i

    if last_human_line < 0:
        return False
    if last_agent_line < 0:
        return True
    return last_human_line > last_agent_line


def check_awaiting_human() -> bool:
    """Return True if we should skip this heartbeat (waiting for human)."""
    if AWAITING_FILE.exists():
        if not load_pending_human() and not has_new_human_messages():
            log("Awaiting human response. Skipping heartbeat.")
            return True
        else:
            AWAITING_FILE.unlink(missing_ok=True)
    return False


# ─── Session management ──────────────────────────────────────────────

def load_session_id() -> str | None:
    if SESSION_FILE.exists():
        sid = SESSION_FILE.read_text().strip()
        return sid if sid else None
    if LEGACY_SESSION_FILE.exists():
        sid = LEGACY_SESSION_FILE.read_text().strip()
        return sid if sid else None
    return None


def save_session_id(session_id: str):
    SESSION_FILE.write_text(session_id)


# ─── Pending human wakeups ───────────────────────────────────────────

def load_pending_human() -> dict | None:
    if not PENDING_HUMAN_FILE.exists():
        return None

    try:
        data = json.loads(PENDING_HUMAN_FILE.read_text())
    except Exception:
        return None

    return data if isinstance(data, dict) else None


def clear_pending_human_if_unchanged(expected_mailbox_id: str | None):
    if not expected_mailbox_id or not PENDING_HUMAN_FILE.exists():
        return

    data = load_pending_human()
    if data and data.get("mailbox_id") == expected_mailbox_id:
        PENDING_HUMAN_FILE.unlink(missing_ok=True)


async def sleep_with_wakeup(minutes: int):
    total_seconds = max(0, minutes * 60)
    slept = 0

    while slept < total_seconds and not shutdown_requested:
        if load_pending_human():
            log("Pending human mailbox message detected. Waking immediately.")
            return
        if AWAITING_FILE.exists() and has_new_human_messages():
            log("New human mailbox message detected while awaiting input. Waking immediately.")
            return

        await asyncio.sleep(1)
        slept += 1


# ─── Prompt building ─────────────────────────────────────────────────

def build_prompt(first_heartbeat: bool, pending_human: dict | None) -> str:
    if pending_human:
        pending_id = pending_human.get("mailbox_id", "unknown")
        return (
            "New human mailbox messages have arrived.\n\n"
            "1. Read mailbox/MAILBOX.jsonl immediately.\n"
            "2. Find and address the newest human message(s).\n"
            "3. Continue the same task in the current session.\n"
            "4. If you need to reply, run: uv run python .claude/skills/mailbox-operate/scripts/send_mailbox.py --kind update --message \"...\"\n\n"
            f"Latest pending mailbox id: {pending_id}\n"
            f"Working directory: {AGENT_DIR}"
        )

    if first_heartbeat:
        return (
            "You are {{AGENT_NAME}}. This is your first heartbeat.\n\n"
            "Read CLAUDE.md to understand your behavioral rules.\n"
            "Read mailbox/MAILBOX.jsonl for any initial instructions.\n"
            "For mailbox operations, run scripts directly via Bash (see CLAUDE.md Skills Usage section).\n"
            "If you need to pause for a human reply, use send_mailbox.py with --await-reply.\n"
            "Then begin working on your assigned task.\n\n"
            f"Working directory: {AGENT_DIR}"
        )
    else:
        return (
            "Heartbeat wakeup for {{AGENT_NAME}}.\n\n"
            "1. Read mailbox updates: uv run python .claude/skills/mailbox-operate/scripts/read_mailbox.py\n"
            "2. If you need to pause for a human reply, use send_mailbox.py with --await-reply and stop.\n"
            "3. Otherwise, continue your current work.\n\n"
            f"Working directory: {AGENT_DIR}"
        )


# ─── Agent invocation ────────────────────────────────────────────────

async def invoke_agent(prompt: str, max_turns: int, max_budget: float) -> str | None:
    session_id = load_session_id()

    options = ClaudeAgentOptions(
        cwd=str(AGENT_DIR),
        allowed_tools=[
            "Read", "Write", "Edit", "Bash", "Glob", "Grep",
            "WebSearch", "WebFetch", "Agent",
        ],
        max_turns=max_turns,
        max_budget_usd=max_budget,
        permission_mode="bypassPermissions",
    )

    if session_id:
        options.resume = session_id
        log(f"Resuming session: {session_id}")
    else:
        log("Starting new session")

    new_session_id = None

    async for message in query(prompt=prompt, options=options):
        if isinstance(message, RateLimitEvent):
            info = message.rate_limit_info
            ratelimit = {
                "ts": utcnow(),
                "provider": "claude",
                "status": info.status,
                "resets_at": info.resets_at,
                "rate_limit_type": info.rate_limit_type,
            }
            RATELIMIT_FILE.write_text(json.dumps(ratelimit))
            log(f"Rate limit: {info.status} (type={info.rate_limit_type})")

        if isinstance(message, AssistantMessage):
            for block in message.content:
                if hasattr(block, "text"):
                    log(f"Agent: {block.text[:200]}")
                elif hasattr(block, "name"):
                    log(f"Tool call: {block.name}")

        if isinstance(message, ResultMessage):
            new_session_id = message.session_id

            if message.subtype == "success":
                log(f"Heartbeat completed. Turns: {message.num_turns}, "
                    f"Cost: ${message.total_cost_usd or 0:.4f}")
            elif message.subtype == "error_max_turns":
                log(f"Hit max turns ({max_turns}). Will resume next heartbeat.")
            elif message.subtype == "error_max_budget_usd":
                log(f"Hit budget limit (${max_budget}). Will resume next heartbeat.")
            else:
                log(f"Agent ended with: {message.subtype}")

    if new_session_id:
        save_session_id(new_session_id)

    return new_session_id


# ─── Interval ────────────────────────────────────────────────────────

def get_interval(default: int) -> int:
    """Read interval from Runtime/interval file, falling back to CLI default."""
    if INTERVAL_FILE.exists():
        try:
            value = int(INTERVAL_FILE.read_text().strip())
            if value > 0:
                return value
        except (ValueError, OSError):
            pass
    return default


# ─── Work schedule ──────────────────────────────────────────────────

def load_work_schedule() -> dict | None:
    """Load Runtime/work_schedule.json. Returns None if absent or invalid."""
    if not WORK_SCHEDULE_FILE.exists():
        return None
    try:
        data = json.loads(WORK_SCHEDULE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return None
    if not isinstance(data, dict):
        return None
    windows = data.get("windows")
    if not isinstance(windows, list) or len(windows) == 0:
        return None
    return data


def _parse_hhmm(hhmm: str) -> tuple[int, int]:
    parts = hhmm.strip().split(":")
    return int(parts[0]), int(parts[1])


def is_in_work_window(schedule: dict) -> bool:
    """Check if current time falls within any configured work window."""
    from zoneinfo import ZoneInfo

    tz_name = schedule.get("timezone", "UTC")
    try:
        tz = ZoneInfo(tz_name)
    except Exception:
        tz = ZoneInfo("UTC")

    now = datetime.now(tz)
    iso_weekday = now.isoweekday()  # 1=Mon, 7=Sun
    current_minutes = now.hour * 60 + now.minute

    for window in schedule.get("windows", []):
        days = window.get("days", [])
        if iso_weekday not in days:
            continue
        start_h, start_m = _parse_hhmm(window.get("start", "00:00"))
        end_h, end_m = _parse_hhmm(window.get("end", "23:59"))
        start_total = start_h * 60 + start_m
        end_total = end_h * 60 + end_m
        if start_total <= current_minutes < end_total:
            return True
    return False


def seconds_until_next_window(schedule: dict) -> int:
    """Calculate seconds from now until the next work window opens."""
    from zoneinfo import ZoneInfo

    tz_name = schedule.get("timezone", "UTC")
    try:
        tz = ZoneInfo(tz_name)
    except Exception:
        tz = ZoneInfo("UTC")

    now = datetime.now(tz)
    iso_weekday = now.isoweekday()
    current_minutes = now.hour * 60 + now.minute

    best = None

    for day_offset in range(8):  # check up to 7 days ahead
        check_day = ((iso_weekday - 1 + day_offset) % 7) + 1

        for window in schedule.get("windows", []):
            days = window.get("days", [])
            if check_day not in days:
                continue
            start_h, start_m = _parse_hhmm(window.get("start", "00:00"))
            start_total = start_h * 60 + start_m

            if day_offset == 0 and start_total <= current_minutes:
                continue  # this window already started today

            minutes_away = day_offset * 1440 + (start_total - current_minutes)
            seconds_away = minutes_away * 60 - now.second
            if best is None or seconds_away < best:
                best = seconds_away

    return max(best or 3600, 60)  # fallback 1h, minimum 1min


async def sleep_until_work_window(schedule: dict):
    """Sleep until the next work window opens, waking on human messages."""
    wait_seconds = seconds_until_next_window(schedule)
    log(f"Off hours. Sleeping {wait_seconds // 60} minutes until next work window.")

    slept = 0
    while slept < wait_seconds and not shutdown_requested:
        if load_pending_human():
            log("Human message received during off hours. Waking immediately.")
            return
        if AWAITING_FILE.exists() and has_new_human_messages():
            log("New human message during off hours. Waking immediately.")
            return
        # Re-check schedule every 60s in case file was updated
        if slept > 0 and slept % 60 == 0:
            fresh = load_work_schedule()
            if fresh is None or is_in_work_window(fresh):
                log("Work schedule changed. Now in work window.")
                return
        await asyncio.sleep(1)
        slept += 1


def check_work_schedule() -> bool:
    """Return True if currently off hours and heartbeat should be skipped."""
    schedule = load_work_schedule()
    if schedule is None:
        return False  # no schedule = 24/7
    if is_in_work_window(schedule):
        return False
    STATE_FILE.write_text("off_hours")
    return True


# ─── Main loop ────────────────────────────────────────────────────────

async def main():
    parser = argparse.ArgumentParser(description="Heartbeat launcher for {{AGENT_NAME}}")
    parser.add_argument("--interval", type=int, default=20,
                        help="Heartbeat interval in minutes (default: 20)")
    parser.add_argument("--max-turns", type=int, default=50,
                        help="Max agent turns per heartbeat (default: 50)")
    parser.add_argument("--max-budget", type=float, default=5.0,
                        help="Max USD budget per heartbeat (default: 5.0)")
    args = parser.parse_args()

    check_and_write_pid()

    # Write initial interval to file so platform can read/modify it
    INTERVAL_FILE.write_text(str(args.interval))

    print("============================================================")
    print("{{AGENT_NAME}} - Claude runtime starting")
    print(f"Interval:  {args.interval} minutes")
    print(f"PID:       {os.getpid()}")
    print(f"Directory: {AGENT_DIR}")
    print("============================================================")
    print()

    first_heartbeat = load_session_id() is None

    try:
        while not shutdown_requested:
            interval = get_interval(args.interval)

            if check_work_schedule():
                await sleep_until_work_window(load_work_schedule())
                continue

            # Record heartbeat
            HEARTBEAT_FILE.write_text(utcnow())
            STATE_FILE.write_text("running")

            log("Heartbeat — starting")

            # Check if waiting for human
            if check_awaiting_human():
                log(f"Sleeping {interval} minutes...")
                await sleep_with_wakeup(interval)
                continue

            # Build prompt and invoke
            pending_human = load_pending_human()
            pending_before = pending_human.get("mailbox_id") if pending_human else None
            prompt = build_prompt(first_heartbeat, pending_human)

            try:
                await invoke_agent(prompt, args.max_turns, args.max_budget)
            except Exception as e:
                log(f"Runtime error: {e}")
            finally:
                clear_pending_human_if_unchanged(pending_before)

            first_heartbeat = False

            if load_pending_human():
                log("More human mailbox messages are pending. Continuing immediately.")
                continue

            interval = get_interval(args.interval)
            log(f"Heartbeat complete. Sleeping {interval} minutes...")
            await sleep_with_wakeup(interval)
    finally:
        cleanup_pid()
        log("{{AGENT_NAME}} stopped.")


if __name__ == "__main__":
    asyncio.run(main())
