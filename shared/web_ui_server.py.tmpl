<script>
let autoSyncTimer = null;
let statusBusy = false;
let historyBusy = false;
let lastStatusFingerprint = '';
let lastHistoryFingerprint = '';
function nowText() {
  const d = new Date();
  return d.toLocaleTimeString();
}

function setSyncMeta(text) {
  document.getElementById('syncMeta').textContent = text;
}

function shouldStickToBottom(root) {
  const distance = root.scrollHeight - root.scrollTop - root.clientHeight;
  return distance < 80;
}

function setBadge(id, isOn) {
  const node = document.getElementById(id);
  node.textContent = isOn ? 'OPEN' : 'OFF';
  node.className = `badge ${isOn ? 'on' : 'off'}`;
}

function setProcess(prefix, processData) {
  const on = processData && processData.state === 'running';
  setBadge(`${prefix}Badge`, on);
  const state = processData && processData.state ? processData.state : 'unknown';
  const pid = processData && processData.pid ? `PID ${processData.pid}` : 'PID none';
  document.getElementById(`${prefix}Meta`).textContent = `${pid} · ${state}`;
}

function renderPills(data) {
  const items = [
    {label: 'Awaiting Human', on: Boolean(data.awaiting_human)},
    {label: 'Runner Online', on: data.runner && data.runner.state === 'running'},
    {label: 'Bridge Online', on: data.bridge && data.bridge.state === 'running'},
    {label: 'UI Online', on: data.web_ui && data.web_ui.state === 'running'}
  ];
  const root = document.getElementById('statusPills');
  root.innerHTML = '';
  for (const item of items) {
    const node = document.createElement('span');
    node.className = `pill ${item.on ? 'on' : 'off'}`;
    node.textContent = `${item.label}: ${item.on ? 'ON' : 'OFF'}`;
    root.appendChild(node);
  }
}

function statusFingerprint(data) {
  const parts = [
    data.agent || '',
    data.interaction_mode || '',
    data.provider || '',
    data.runtime_state || '',
    data.last_heartbeat || '',
    data.awaiting_human ? '1' : '0',
    data.runner ? `${data.runner.state || ''}:${data.runner.pid || ''}` : '',
    data.bridge ? `${data.bridge.state || ''}:${data.bridge.pid || ''}` : '',
    data.web_ui ? `${data.web_ui.state || ''}:${data.web_ui.pid || ''}` : '',
  ];
  return parts.join('|');
}

async function loadStatus(force = false) {
  if (statusBusy) return;
  statusBusy = true;
  try {
    const resp = await fetch('/api/status');
    const data = await resp.json();
    const fp = statusFingerprint(data);
    if (!force && fp === lastStatusFingerprint) {
      return;
    }
    lastStatusFingerprint = fp;
    setProcess('runner', data.runner);
    setProcess('bridge', data.bridge);
    setProcess('ui', data.web_ui);
    document.getElementById('agentName').textContent = data.agent || '-';
    document.getElementById('interactionMode').textContent = data.interaction_mode || '-';
    document.getElementById('provider').textContent = data.provider || '-';
    document.getElementById('runtimeState').textContent = data.runtime_state || '-';
    document.getElementById('heartbeatMeta').textContent = `Last heartbeat: ${data.last_heartbeat || 'none'}`;
    renderPills(data);
  } finally {
    statusBusy = false;
  }
}

function renderMessage(item) {
  const wrap = document.createElement('div');
  const isHuman = item.role === 'human';
  wrap.className = `msg ${isHuman ? 'human' : 'agent'}`;

  const meta = document.createElement('div');
  meta.className = 'msg-meta';
  meta.textContent = `${item.ts} · ${item.role} · ${item.task_id}`;
  wrap.appendChild(meta);

  const bubble = document.createElement('div');
  bubble.className = `bubble ${isHuman ? 'human' : 'agent'}`;
  bubble.textContent = item.message;
  wrap.appendChild(bubble);
  return wrap;
}

async function loadHistory() {
  if (historyBusy) return;
  historyBusy = true;
  try {
    const resp = await fetch('/api/history?limit=50');
    const data = await resp.json();
    const items = data.items || [];
    const last = items.length ? items[items.length - 1] : null;
    const fp = `${items.length}:${last ? last.id : ''}:${last ? last.ts : ''}`;
    if (fp === lastHistoryFingerprint) {
      return;
    }
    lastHistoryFingerprint = fp;
    const root = document.getElementById('history');
    const keepBottom = shouldStickToBottom(root);
    root.innerHTML = '';
    for (const item of items) {
      root.appendChild(renderMessage(item));
    }
    if (keepBottom) {
      root.scrollTop = root.scrollHeight;
    }
  } finally {
    historyBusy = false;
  }
}

async function sendMessage() {
  const input = document.getElementById('message');
  const text = input.value.trim();
  const result = document.getElementById('sendResult');
  result.textContent = '';
  if (!text) {
    result.textContent = 'Message is empty';
    return;
  }
  const resp = await fetch('/api/send', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({message: text})
  });
  const data = await resp.json();
  if (!resp.ok) {
    result.textContent = `Error: ${data.error || 'send failed'}`;
    return;
  }
  input.value = '';
  result.textContent = `Sent as ${data.id}`;
  await refreshAll(true);
}

async function refreshAll(force = false) {
  try {
    await Promise.all([loadStatus(force), loadHistory()]);
    setSyncMeta(`Last sync ${nowText()}`);
  } catch (err) {
    setSyncMeta('Sync failed');
  }
}

function toggleAutoSync() {
  const enabled = document.getElementById('autoSync').checked;
  if (!enabled) {
    if (autoSyncTimer) {
      clearInterval(autoSyncTimer);
      autoSyncTimer = null;
    }
    setSyncMeta('Auto sync off');
    return;
  }
  if (autoSyncTimer) clearInterval(autoSyncTimer);
  const interval = document.hidden ? 5000 : 2000;
  autoSyncTimer = setInterval(() => {
    if (!document.getElementById('autoSync').checked) return;
    refreshAll(false);
  }, interval);
  refreshAll(false);
}

document.addEventListener('visibilitychange', () => {
  if (document.getElementById('autoSync').checked) {
    toggleAutoSync();
  }
});

refreshAll(true);
toggleAutoSync();
</script>
 </body>
</html>
"""


class Handler(BaseHTTPRequestHandler):
    def log_message(self, format: str, *args) -> None:
        return

    def _json(self, payload: dict | list, status_code: int = 200) -> None:
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status_code)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _html(self, body: str) -> None:
        data = body.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        if parsed.path == "/":
            self._html(HTML)
            return
        if parsed.path == "/api/status":
            self._json(status_payload())
            return
        if parsed.path == "/api/history":
            query = parse_qs(parsed.query)
            try:
                limit = int(query.get("limit", ["50"])[0])
            except Exception:
                limit = 50
            limit = max(1, min(limit, 200))
            self._json({"items": history_payload(limit)})
            return

        self._json({"error": "not found"}, 404)

    def do_POST(self) -> None:
        parsed = urlparse(self.path)
        if parsed.path != "/api/send":
            self._json({"error": "not found"}, 404)
            return

        try:
            size = int(self.headers.get("Content-Length", "0"))
        except Exception:
            size = 0
        raw = self.rfile.read(size) if size > 0 else b"{}"
        try:
            payload = json.loads(raw.decode("utf-8"))
        except Exception:
            self._json({"error": "invalid json"}, 400)
            return

        message = str(payload.get("message", "")).strip()
        if not message:
            self._json({"error": "message must not be empty"}, 400)
            return

        entry = append_message(
            MAILBOX,
            role="human",
            task_id="task.human.reply",
            message=message,
            extra={"source": "web-ui"},
        )
        write_pending_human(entry)
        self._json({"ok": True, "id": entry["id"], "ts": entry["ts"]})


def main() -> None:
    parser = argparse.ArgumentParser(description="MailBox UI server for {{AGENT_NAME}}")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8080)
    args = parser.parse_args()

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(
        f"[{utcnow()}] [web-ui] Serving {{AGENT_NAME}} MailBox at http://{args.host}:{args.port}",
        flush=True,
    )
    server.serve_forever()


if __name__ == "__main__":
    main()
