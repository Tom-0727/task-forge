"""Simple MailBox UI for mailbox history, status, and human input."""

from __future__ import annotations

import argparse
import json
import os
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

from mailbox_io import append_message, read_messages

AGENT_DIR = Path(__file__).resolve().parent
MAILBOX = AGENT_DIR / "mailbox" / "MAILBOX.jsonl"
RUNTIME_DIR = AGENT_DIR / "Runtime"
PENDING_HUMAN_FILE = RUNTIME_DIR / "pending_human.json"
RUNNER_PID_FILE = RUNTIME_DIR / "pid"
BRIDGE_PID_FILE = RUNTIME_DIR / "bridge.pid"
WEB_UI_PID_FILE = RUNTIME_DIR / "web_ui.pid"
PROVIDER_FILE = RUNTIME_DIR / "runtime_provider"
STATE_FILE = RUNTIME_DIR / "state"
HEARTBEAT_FILE = RUNTIME_DIR / "last_heartbeat"
AWAITING_FILE = RUNTIME_DIR / "awaiting_human"
INTERACTION_MODE_FILE = RUNTIME_DIR / "interaction_mode"


def read_text(path: Path) -> str:
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8").strip()


def utcnow() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def format_ts(value: str) -> str:
    text = (value or "").strip()
    if not text:
        return "none"
    try:
        dt = datetime.fromisoformat(text.replace("Z", "+00:00"))
    except Exception:
        return text.replace("T", " ").replace("Z", "").strip()
    return dt.astimezone().strftime("%Y-%m-%d %H:%M")


def is_running(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def pid_status(path: Path) -> dict:
    raw = read_text(path)
    if not raw:
        return {"state": "stopped", "pid": ""}
    try:
        pid = int(raw)
    except Exception:
        return {"state": "stale", "pid": raw}
    if is_running(pid):
        return {"state": "running", "pid": str(pid)}
    return {"state": "stale", "pid": str(pid)}


def status_payload() -> dict:
    heartbeat = read_text(HEARTBEAT_FILE)
    return {
        "agent": "{{AGENT_NAME}}",
        "interaction_mode": read_text(INTERACTION_MODE_FILE) or "unknown",
        "provider": read_text(PROVIDER_FILE) or "none",
        "runtime_state": read_text(STATE_FILE) or "unknown",
        "runner": pid_status(RUNNER_PID_FILE),
        "bridge": pid_status(BRIDGE_PID_FILE),
        "web_ui": pid_status(WEB_UI_PID_FILE),
        "last_heartbeat": format_ts(heartbeat) if heartbeat else "none",
        "awaiting_human": AWAITING_FILE.exists(),
    }


def history_payload(limit: int) -> list[dict]:
    messages = read_messages(MAILBOX)
    rendered: list[dict] = []
    for message in messages[-limit:]:
        rendered.append(
            {
                "id": str(message.get("id", "")),
                "ts": format_ts(str(message.get("ts", ""))),
                "role": str(message.get("role", "")),
                "task_id": str(message.get("task_id", "")),
                "message": str(message.get("message", "")),
            }
        )
    return rendered


def write_pending_human(entry: dict) -> None:
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "mailbox_id": entry["id"],
        "ts": entry["ts"],
        "source": "web-ui",
    }
    PENDING_HUMAN_FILE.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


