#!/usr/bin/env python3
"""
add_scheduled.py — append a new Scheduled Task to scheduled_tasks.json.

Concept substitution point: "Scheduled Task". Rename mechanically if renamed upstream.

Writes `<agent_workdir>/scheduled_tasks.json` with the A08 atomic-rename
pattern. Allocates the next `s<n>` id and enforces the kind/weekdays/date
cross-flag rules from architecture §i.
"""

from __future__ import annotations

import argparse
import importlib.util
import re
import sys
from datetime import datetime
from importlib.machinery import SourceFileLoader
from pathlib import Path

_TIME_RE = re.compile(r"^\d{2}:\d{2}$")

_HERE = Path(__file__).resolve().parent


def _load_common():
    for candidate in (_HERE / "_common.py", _HERE / "_common.py.tmpl"):
        if candidate.exists():
            loader = SourceFileLoader("_todo_common", str(candidate))
            spec = importlib.util.spec_from_loader(loader.name, loader)
            if spec is None:
                continue
            mod = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod
    raise SystemExit(f"_common.py(.tmpl) not found in {_HERE}")


_common = _load_common()
allocate_next_id = _common.allocate_next_id
atomic_write_json = _common.atomic_write_json
load_list_json = _common.load_list_json


VALID_WEEKDAYS = ("MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN")


def _validate_time(value: str) -> str:
    if not _TIME_RE.match(value):
        raise SystemExit(
            f"--time must be HH:MM (24-hour, zero-padded); got '{value}'"
        )
    try:
        datetime.strptime(value, "%H:%M")
    except ValueError as exc:
        raise SystemExit(f"--time must be HH:MM (24-hour); got '{value}': {exc}") from exc
    return value


def _validate_date(value: str) -> str:
    try:
        datetime.strptime(value, "%Y-%m-%d")
    except ValueError as exc:
        raise SystemExit(f"--date must be YYYY-MM-DD; got '{value}': {exc}") from exc
    return value


def _parse_weekdays(value: str) -> list[str]:
    raw = [token.strip().upper() for token in value.split(",") if token.strip()]
    if not raw:
        raise SystemExit("--weekdays must list at least one day")
    for token in raw:
        if token not in VALID_WEEKDAYS:
            raise SystemExit(
                f"--weekdays entries must be one of {','.join(VALID_WEEKDAYS)}; got '{token}'"
            )
    return raw


def _build_subtasks(texts: list[str]) -> list[dict]:
    return [{"id": idx, "text": text} for idx, text in enumerate(texts, start=1)]


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Append a Scheduled Task (atomic write).")
    parser.add_argument("--title", required=True)
    parser.add_argument("--description", default="")
    parser.add_argument("--kind", required=True, choices=("weekly", "date"))
    parser.add_argument("--time", required=True, dest="clock_time")
    parser.add_argument("--weekdays", default=None)
    parser.add_argument("--date", default=None, dest="one_shot_date")
    parser.add_argument("--subtask", action="append", default=None)
    parser.add_argument("--agent-workdir", default=None)
    args = parser.parse_args(argv)

    clock_time = _validate_time(args.clock_time)

    if args.kind == "weekly":
        if args.weekdays is None:
            raise SystemExit("--kind weekly requires --weekdays")
        if args.one_shot_date is not None:
            raise SystemExit("--kind weekly forbids --date")
        reminder_at = {
            "kind": "weekly",
            "time": clock_time,
            "weekdays": _parse_weekdays(args.weekdays),
        }
    else:  # kind == "date"
        if args.one_shot_date is None:
            raise SystemExit("--kind date requires --date")
        if args.weekdays is not None:
            raise SystemExit("--kind date forbids --weekdays")
        reminder_at = {
            "kind": "date",
            "time": clock_time,
            "date": _validate_date(args.one_shot_date),
        }

    subtasks = _build_subtasks(args.subtask or [])

    agent_workdir = (
        Path(args.agent_workdir).resolve() if args.agent_workdir else Path.cwd().resolve()
    )
    store_path = agent_workdir / "scheduled_tasks.json"

    items = load_list_json(store_path)
    new_id = allocate_next_id(items, "s")
    items.append(
        {
            "id": new_id,
            "title": args.title,
            "description": args.description,
            "subtasks": subtasks,
            "reminder_at": reminder_at,
        }
    )
    atomic_write_json(store_path, items)

    print(new_id)
    return 0


if __name__ == "__main__":
    sys.exit(main())
