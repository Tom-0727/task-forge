#!/usr/bin/env python3
"""
pre_heartbeat.py — scan Scheduled Tasks and publish due reminders for this minute.

Concept substitution point: "Scheduled Task". Rename mechanically if renamed upstream.

This script is the pre-heartbeat hook. It reads the agent's
`scheduled_tasks.json`, decides which `s<n>` ids are due at the given
minute, and publishes two Runtime/ files that the wake-up prompt builder
(providers/claude/run_claude.py.tmpl, landing in a later slice) consumes:

  - Runtime/due_reminders.json     — OVERWRITTEN each run with the list
                                     of ids due this minute (may be `[]`).
  - Runtime/scheduled_delivered.json — APPEND-ONLY log of
                                     `"<id>@<YYYY-MM-DDTHH:MM>"` tokens,
                                     de-duplicated so restarts within the
                                     same minute do not re-deliver.

Due rule (per §i):
  - `reminder_at.time == now.HH:MM` AND
  - for `kind=weekly`: weekday-of-now (as "MON".."SUN") ∈ `reminder_at.weekdays`
  - for `kind=date`:  `now.YYYY-MM-DD == reminder_at.date`

`--now YYYY-MM-DDTHH:MM` is optional; when absent we take `datetime.now()`.
Tests inject `--now` for determinism; production invocations from the
runtime will omit it.
"""

from __future__ import annotations

import argparse
import importlib.util
import sys
from datetime import datetime
from importlib.machinery import SourceFileLoader
from pathlib import Path

_HERE = Path(__file__).resolve().parent

_WEEKDAYS = ("MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN")


def _load_common():
    for candidate in (_HERE / "_common.py", _HERE / "_common.py.tmpl"):
        if candidate.exists():
            loader = SourceFileLoader("_todo_common", str(candidate))
            spec = importlib.util.spec_from_loader(loader.name, loader)
            if spec is None:
                continue
            mod = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod
    raise SystemExit(f"_common.py(.tmpl) not found in {_HERE}")


_common = _load_common()
load_list_json = _common.load_list_json
atomic_write_json = _common.atomic_write_json


def _parse_now(value: str | None) -> datetime:
    if value is None:
        return datetime.now().replace(second=0, microsecond=0)
    try:
        return datetime.strptime(value, "%Y-%m-%dT%H:%M")
    except ValueError as exc:
        raise SystemExit(
            f"--now must be YYYY-MM-DDTHH:MM (24-hour, zero-padded); got '{value}': {exc}"
        ) from exc


def _weekday_token(dt: datetime) -> str:
    return _WEEKDAYS[dt.weekday()]


def _is_due(task: dict, now_dt: datetime) -> bool:
    ra = task.get("reminder_at") or {}
    if ra.get("time") != now_dt.strftime("%H:%M"):
        return False
    kind = ra.get("kind")
    if kind == "weekly":
        return _weekday_token(now_dt) in (ra.get("weekdays") or [])
    if kind == "date":
        return ra.get("date") == now_dt.strftime("%Y-%m-%d")
    return False


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Scan Scheduled Tasks and publish due reminders for this minute."
    )
    parser.add_argument("--agent-workdir", default=None)
    parser.add_argument("--now", default=None, dest="now_str")
    args = parser.parse_args(argv)

    now_dt = _parse_now(args.now_str)
    now_minute_str = now_dt.strftime("%Y-%m-%dT%H:%M")

    agent_workdir = (
        Path(args.agent_workdir).resolve() if args.agent_workdir else Path.cwd().resolve()
    )
    tasks = load_list_json(agent_workdir / "scheduled_tasks.json")

    due_ids = [task["id"] for task in tasks if _is_due(task, now_dt)]

    runtime_dir = agent_workdir / "Runtime"
    atomic_write_json(runtime_dir / "due_reminders.json", due_ids)

    delivered_path = runtime_dir / "scheduled_delivered.json"
    delivered = load_list_json(delivered_path)
    delivered_set = set(delivered)
    new_tokens = [
        token
        for token in (f"{task_id}@{now_minute_str}" for task_id in due_ids)
        if token not in delivered_set
    ]
    if new_tokens:
        delivered.extend(new_tokens)
        atomic_write_json(delivered_path, delivered)

    print(f"due={len(due_ids)} new_delivered={len(new_tokens)}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
